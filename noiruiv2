local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local NoirUI = {}

function NoirUI:CreateWindow(settings)

    -- AUTO REMOVE UI CŨ
    local old = game.CoreGui:FindFirstChild("NoirUI")
    if old then old:Destroy() end

    _G.NoirFloatPos = _G.NoirFloatPos or UDim2.new(0,20,0.5,-20)

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "NoirUI"
    ScreenGui.Parent = game.CoreGui

    -- MAIN
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 320, 0, 240)
    Main.Position = UDim2.new(0.5, -160, 0.5, -120)
    Main.BackgroundColor3 = Color3.fromRGB(18,18,18)
    Main.BackgroundTransparency = 1
    Instance.new("UICorner", Main)

    TweenService:Create(Main, TweenInfo.new(0.3), {
        BackgroundTransparency = 0
    }):Play()

    -- DRAG MAIN
    local dragging, dragStart, startPos

    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    -- TITLE
    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 35)
    Title.Text = settings.Name or "Noir UI"
    Title.TextColor3 = Color3.fromRGB(255,255,255)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16

    -- SCROLL
    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1, -10, 1, -40)
    Container.Position = UDim2.new(0, 5, 0, 35)
    Container.BackgroundTransparency = 1
    Container.ScrollBarThickness = 4
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y

    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 6)

    local ACCENT = Color3.fromRGB(170,85,255)

    local Window = {}

    -- BUTTON
    function Window:CreateButton(opt)
        local Btn = Instance.new("TextButton", Container)
        Btn.Size = UDim2.new(1, 0, 0, 35)
        Btn.Text = opt.Name or "Button"
        Btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        Btn.TextColor3 = Color3.fromRGB(255,255,255)
        Instance.new("UICorner", Btn)

        Btn.MouseButton1Click:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.1), {
                BackgroundColor3 = ACCENT
            }):Play()

            task.wait(0.1)

            TweenService:Create(Btn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(30,30,30)
            }):Play()

            if opt.Callback then opt.Callback() end
        end)
    end

    -- TOGGLE
    function Window:CreateToggle(opt)
        local Btn = Instance.new("TextButton", Container)
        Btn.Size = UDim2.new(1, 0, 0, 35)
        Btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        Btn.TextColor3 = Color3.fromRGB(255,255,255)
        Instance.new("UICorner", Btn)

        local state = false
        Btn.Text = (opt.Name or "Toggle") .. ": OFF"

        Btn.MouseButton1Click:Connect(function()
            state = not state
            Btn.Text = (opt.Name or "Toggle") .. ": " .. (state and "ON" or "OFF")

            TweenService:Create(Btn, TweenInfo.new(0.2), {
                BackgroundColor3 = state and ACCENT or Color3.fromRGB(30,30,30)
            }):Play()

            if opt.Callback then opt.Callback(state) end
        end)
    end

    -- SLIDER
    function Window:CreateSlider(opt)
        local Frame = Instance.new("Frame", Container)
        Frame.Size = UDim2.new(1, 0, 0, 50)
        Frame.BackgroundTransparency = 1

        local Label = Instance.new("TextLabel", Frame)
        Label.Size = UDim2.new(1, 0, 0, 20)
        Label.Text = (opt.Name or "Slider") .. ": " .. (opt.Default or 0)
        Label.TextColor3 = Color3.fromRGB(255,255,255)
        Label.BackgroundTransparency = 1
        Label.TextSize = 14

        local Bar = Instance.new("Frame", Frame)
        Bar.Size = UDim2.new(1, 0, 0, 10)
        Bar.Position = UDim2.new(0, 0, 0, 30)
        Bar.BackgroundColor3 = Color3.fromRGB(40,40,40)
        Instance.new("UICorner", Bar)

        local Fill = Instance.new("Frame", Bar)
        Fill.Size = UDim2.new(0, 0, 1, 0)
        Fill.BackgroundColor3 = ACCENT
        Instance.new("UICorner", Fill)

        local dragging = false
        local min = opt.Min or 0
        local max = opt.Max or 100

        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local pos = (input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X
                pos = math.clamp(pos, 0, 1)

                Fill.Size = UDim2.new(pos, 0, 1, 0)

                local value = math.floor(min + (max - min) * pos)
                Label.Text = (opt.Name or "Slider") .. ": " .. value

                if opt.Callback then opt.Callback(value) end
            end
        end)

        Bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
            end
        end)

        Bar.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end

    -- FLOAT BUTTON
    local Float = Instance.new("TextButton", ScreenGui)
    Float.Size = UDim2.new(0, 0, 0, 0)
    Float.Position = _G.NoirFloatPos
    Float.Text = "⚡"
    Float.BackgroundColor3 = ACCENT
    Float.TextColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", Float)

    TweenService:Create(Float, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Size = UDim2.new(0, 40, 0, 40)
    }):Play()

    local visible = true

    Float.MouseButton1Click:Connect(function()
        visible = not visible

        TweenService:Create(Main, TweenInfo.new(0.2), {
            BackgroundTransparency = visible and 0 or 1
        }):Play()

        task.wait(0.2)
        Main.Visible = visible

        TweenService:Create(Float, TweenInfo.new(0.1), {
            Size = UDim2.new(0, 35, 0, 35)
        }):Play()

        task.wait(0.1)

        TweenService:Create(Float, TweenInfo.new(0.1), {
            Size = UDim2.new(0, 40, 0, 40)
        }):Play()
    end)

    -- DRAG FLOAT
    local draggingF, dragStartF, startPosF

    Float.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingF = true
            dragStartF = input.Position
            startPosF = Float.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingF = false
                    _G.NoirFloatPos = Float.Position
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if draggingF and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStartF

            Float.Position = UDim2.new(
                startPosF.X.Scale,
                startPosF.X.Offset + delta.X,
                startPosF.Y.Scale,
                startPosF.Y.Offset + delta.Y
            )
        end
    end)

    return Window
end

return NoirUI
