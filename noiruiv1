        tLabel.TextXAlignment = Enum.TextXAlignment.Left

        local mLabel = Instance.new("TextLabel", NotifyFrame)
        mLabel.Size = UDim2.new(1, -20, 0, 35)
        mLabel.Position = UDim2.new(0, 10, 0, 25)
        mLabel.Text = message
        mLabel.TextColor3 = Color3.new(1, 1, 1)
        mLabel.BackgroundTransparency = 1
        mLabel.TextWrapped = true
        mLabel.TextSize = 12
        mLabel.TextXAlignment = Enum.TextXAlignment.Left

        table.insert(NoirUI.Notifications, 1, NotifyFrame)
        
        -- Sắp xếp vị trí thông báo khi có nhiều cái cùng lúc
        for i, v in ipairs(NoirUI.Notifications) do
            TweenService:Create(v, TweenInfo.new(0.3), {
                Position = UDim2.new(1, -240, 0.8, -(i * 75))
            }):Play()
        end

        task.delay(4, function()
            local t = TweenService:Create(NotifyFrame, TweenInfo.new(0.3), {Position = UDim2.new(1, 20, NotifyFrame.Position.Y.Scale, NotifyFrame.Position.Y.Offset)})
            t:Play()
            t.Completed:Wait()
            NotifyFrame:Destroy()
            table.remove(NoirUI.Notifications, table.find(NoirUI.Notifications, NotifyFrame))
        end)
    end

