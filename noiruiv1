local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

local NoirUI = {}

function NoirUI:CreateWindow(settings)

    local old = game.CoreGui:FindFirstChild("NoirUI")
    if old then old:Destroy() end

    _G.NoirFloatPos = _G.NoirFloatPos or UDim2.new(0,20,0.5,-20)

    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "NoirUI"

    local Blur = Instance.new("BlurEffect", game.Lighting)
    Blur.Size = 0
    TweenService:Create(Blur, TweenInfo.new(0.3), {Size = 12}):Play()

    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 320, 0, 260)
    Main.Position = UDim2.new(0.5, -160, 0.5, -130)
    Main.BackgroundColor3 = Color3.fromRGB(8,8,8)
    Main.BackgroundTransparency = 1
    Instance.new("UICorner", Main)

    TweenService:Create(Main, TweenInfo.new(0.3), {
        BackgroundTransparency = 0
    }):Play()

    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Thickness = 2

    local Glow = Instance.new("UIStroke", Main)
    Glow.Thickness = 6
    Glow.Transparency = 0.7

    task.spawn(function()
        while true do
            for i = 0,1,0.01 do
                local c = Color3.fromHSV(i,1,1)
                Stroke.Color = c
                Glow.Color = c
                task.wait()
            end
        end
    end)

    local function PlaySound()
        if not settings.SoundId then return end
        local s = Instance.new("Sound")
        s.SoundId = settings.SoundId
        s.Volume = 1
        s.Parent = game:GetService("SoundService")
        s:Play()
        game:GetService("Debris"):AddItem(s, 2)
    end

    local function Burst(parent)
        if not settings.IconEffect then return end

        for i = 1,8 do
            local d = Instance.new("Frame")
            d.Size = UDim2.new(0,4,0,4)
            d.BackgroundColor3 = Color3.fromRGB(170,85,255)
            d.BorderSizePixel = 0
            d.Parent = parent

            local a = (i/8)*math.pi*2
            d.Position = UDim2.new(0.5,0,0.5,0)

            TweenService:Create(d, TweenInfo.new(0.4), {
                Position = UDim2.new(0.5 + math.cos(a)*0.2,0,
                                     0.5 + math.sin(a)*0.2,0),
                BackgroundTransparency = 1
            }):Play()

            game:GetService("Debris"):AddItem(d,0.5)
        end
    end

    local function Drag(obj,save)
        local dragging,start,pos

        obj.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                start = i.Position
                pos = obj.Position

                i.Changed:Connect(function()
                    if i.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        if save then _G.NoirFloatPos = obj.Position end
                    end
                end)
            end
        end)

        UIS.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - start
                obj.Position = UDim2.new(pos.X.Scale,pos.X.Offset+d.X,pos.Y.Scale,pos.Y.Offset+d.Y)
            end
        end)
    end

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1,0,0,35)
    Title.Text = settings.Name or "Noir UI"
    Title.TextColor3 = Color3.new(1,1,1)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16

    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1,-10,1,-40)
    Container.Position = UDim2.new(0,5,0,35)
    Container.BackgroundTransparency = 1
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.ScrollBarThickness = 3

    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0,6)

    local ACCENT = Color3.fromRGB(170,85,255)

    local Window = {}

    function Window:CreateButton(opt)
        local b = Instance.new("TextButton", Container)
        b.Size = UDim2.new(1,0,0,35)
        b.Text = opt.Name
        b.BackgroundColor3 = Color3.fromRGB(20,20,20)
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b)

        b.MouseButton1Click:Connect(function()
            PlaySound()
            TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=ACCENT}):Play()
            task.wait(0.1)
            TweenService:Create(b,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(20,20,20)}):Play()
            if opt.Callback then opt.Callback() end
        end)
    end

    function Window:CreateToggle(opt)
        local b = Instance.new("TextButton", Container)
        b.Size = UDim2.new(1,0,0,35)
        b.BackgroundColor3 = Color3.fromRGB(20,20,20)
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b)

        local s = false
        b.Text = opt.Name..": OFF"

        b.MouseButton1Click:Connect(function()
            PlaySound()
            s = not s
            b.Text = opt.Name..": "..(s and "ON" or "OFF")

            TweenService:Create(b,TweenInfo.new(0.2),{
                BackgroundColor3 = s and ACCENT or Color3.fromRGB(20,20,20)
            }):Play()

            if opt.Callback then opt.Callback(s) end
        end)
    end

    function Window:CreateTextBox(opt)

        local box = Instance.new("TextBox", Container)
        box.Size = UDim2.new(1,0,0,35)
        box.BackgroundColor3 = Color3.fromRGB(20,20,20)
        box.TextColor3 = Color3.new(1,1,1)
        box.PlaceholderText = opt.Placeholder or "Enter..."
        box.Text = ""
        box.ClearTextOnFocus = false
        box.Font = Enum.Font.Gotham
        box.TextSize = 14
        Instance.new("UICorner", box)

        local label = Instance.new("TextLabel", box)
        label.Size = UDim2.new(1,0,1,0)
        label.BackgroundTransparency = 1
        label.Text = opt.Name or "TextBox"
        label.TextColor3 = Color3.fromRGB(180,180,180)
        label.Font = Enum.Font.Gotham
        label.TextSize = 12
        label.TextXAlignment = Enum.TextXAlignment.Left

        box.FocusLost:Connect(function(enterPressed)
            if opt.Callback then
                opt.Callback(box.Text, enterPressed)
            end
        end)
    end

    local Float = Instance.new("TextButton", ScreenGui)
    Float.Size = UDim2.new(0,40,0,40)
    Float.Position = _G.NoirFloatPos
    Float.Text = "⚡"
    Float.BackgroundColor3 = Color3.fromRGB(10,10,10)
    Float.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Float)

    Drag(Float,true)

    local visible = true

    Float.MouseButton1Click:Connect(function()
        PlaySound()
        Burst(Float)

        visible = not visible
        Main.Visible = visible

        TweenService:Create(Blur,TweenInfo.new(0.2),{
            Size = visible and 12 or 0
        }):Play()
    end)

    return Window
end

return NoirUI
