                        writefile(KeyPath, KeyInput.Text)
                    end
                    KeyUI:Destroy()
                    StartUI()
                else
                    KeyBtn.Text = "SAI KEY!"
                    task.wait(1)
                    KeyBtn.Text = "XÁC NHẬN"
                end
            end)
        end
    else
        StartUI()
    end

