function NoirUI:Notify(title, message, duration)
    duration = duration or 3.5
    local n = Instance.new("Frame", ScreenGui)
    n.Size = UDim2.new(0, 280, 0, 70)
    n.Position = UDim2.new(1, 20, 0.85, 0)
    n.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)
    local ns = Instance.new("UIStroke", n)
    ns.Color = ACCENT
    n.BackgroundTransparency = 1
    
    local tl = Instance.new("TextLabel", n)
    tl.Size = UDim2.new(1, -15, 0, 22)
    tl.Position = UDim2.new(0, 10, 0, 5)
    tl.Text = title
    tl.TextColor3 = ACCENT
    tl.BackgroundTransparency = 1
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 13
    tl.TextXAlignment = Enum.TextXAlignment.Left
    
    local ml = Instance.new("TextLabel", n)
    ml.Size = UDim2.new(1, -20, 0, 40)
    ml.Position = UDim2.new(0, 10, 0, 28)
    ml.Text = message
    ml.TextColor3 = Color3.new(1, 1, 1)
    ml.BackgroundTransparency = 1
    ml.TextWrapped = true
    ml.TextXAlignment = Enum.TextXAlignment.Left
    ml.TextYAlignment = Enum.TextYAlignment.Top
    ml.Font = Enum.Font.GothamMedium
    ml.TextSize = 11
    
    for i, v in ipairs(NoirUI.Notifications) do
        Tween(v, { Position = UDim2.new(1, -290, 0.85, -(i-1) * 80) }, 0.25)
    end
    table.insert(NoirUI.Notifications, 1, n)
    Tween(n, { BackgroundTransparency = 0, Position = UDim2.new(1, -290, 0.85, 0) }, 0.3, Enum.EasingStyle.Back)
    
    task.delay(duration, function()
        Tween(n, { BackgroundTransparency = 1, Size = UDim2.new(0, 280, 0, 0) }, 0.3)
        task.wait(0.3)
        for i, v in ipairs(NoirUI.Notifications) do
            if v == n then table.remove(NoirUI.Notifications, i) break end
        end
        n:Destroy()
    end)
end

-- // CREATE TAB (có animation slide + fade)
local function CreateTab(name, icon)
    local btn = Instance.new("TextButton", TabScroll)
    btn.Size = UDim2.new(1, -5, 0, 36)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    btn.Text = ""
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    AddHoverPulse(btn, 1.02)
    
    local btnText = Instance.new("TextLabel", btn)
    btnText.Size = UDim2.new(1, -40, 1, 0)
    btnText.Position = UDim2.new(0, icon and 35 or 10, 0, 0)
    btnText.BackgroundTransparency = 1
    btnText.Text = name
    btnText.TextColor3 = Color3.fromRGB(150, 150, 150)
    btnText.Font = Enum.Font.GothamMedium
    btnText.TextSize = 11
    btnText.TextXAlignment = Enum.TextXAlignment.Left
    
    if icon then
        local ic = Instance.new("ImageLabel", btn)
        ic.Size = UDim2.new(0, 20, 0, 20)
        ic.Position = UDim2.new(0, 8, 0.5, -10)
        ic.BackgroundTransparency = 1
        ic.Image = "rbxassetid://" .. tostring(icon)
        ic.ImageColor3 = Color3.fromRGB(150, 150, 150)
    end
    
    local page = Instance.new("ScrollingFrame", Cont)
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ScrollBarThickness = 4
    page.AutomaticCanvasSize = "Y"
    local pageLayout = Instance.new("UIListLayout", page)
    pageLayout.Padding = UDim.new(0, 8)
    pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    
    btn.MouseButton1Click:Connect(function()
        if CurrentTab == page then return end
        -- Fade out + Slide left tab cũ
        if CurrentTab then
            Tween(CurrentTab, { Position = UDim2.new(-0.3, 0, 0, 0), ImageTransparency = 1 }, 0.2)
            task.wait(0.1)
            CurrentTab.Visible = false
            CurrentTab.Position = UDim2.new(0, 0, 0, 0)
        end
        -- Reset các tab button color
        for _, v in pairs(TabScroll:GetChildren()) do
            if v:IsA("TextButton") and v:FindFirstChild("TextLabel") then
                v.TextLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
                if v:FindFirstChild("ImageLabel") then
                    v.ImageLabel.ImageColor3 = Color3.fromRGB(150, 150, 150)
                end
            end
        end
        -- Highlight tab mới
        btnText.TextColor3 = ACCENT
        if btn:FindFirstChild("ImageLabel") then
            btn.ImageLabel.ImageColor3 = ACCENT
        end
        -- Slide + Fade in tab mới
        page.Visible = true
        page.Position = UDim2.new(0.3, 0, 0, 0)
        page.ImageTransparency = 1
        Tween(page, { Position = UDim2.new(0, 0, 0, 0), ImageTransparency = 0 }, 0.25)
        CurrentTab = page
    end)
    
    if not CurrentTab then
        btnText.TextColor3 = ACCENT
        if btn:FindFirstChild("ImageLabel") then btn.ImageLabel.ImageColor3 = ACCENT end
        page.Visible = true
        CurrentTab = page
    end
    
    -- Search filter
    SearchBox.Changed:Connect(function()
        local query = SearchBox.Text:lower()
        if query == "" then
            btn.Visible = true
        else
            btn.Visible = name:lower():find(query) ~= nil
        end
    end)
    
    local TabAPI = { Count = 0, Page = page }
    local function GetOrder() TabAPI.Count = TabAPI.Count + 1 return TabAPI.Count end
    
    function TabAPI:CreateLabel(text)
        local l = Instance.new("TextLabel", page)
        l.Size = UDim2.new(0.95, 0, 0, 22)
        l.BackgroundTransparency = 1
        l.Text = text
        l.TextColor3 = Color3.fromRGB(200, 200, 200)
        l.Font = Enum.Font.GothamMedium
        l.TextSize = 12
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.LayoutOrder = GetOrder()
    end
    
    function TabAPI:CreateButton(opt)
        local b = Instance.new("TextButton", page)
        b.Size = UDim2.new(0.95, 0, 0, 36)
        b.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        b.Text = opt.Name
        b.TextColor3 = Color3.new(1, 1, 1)
        b.Font = Enum.Font.GothamMedium
        b.TextSize = 12
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        b.LayoutOrder = GetOrder()
        AddHoverPulse(b, 1.02)
        b.MouseButton1Click:Connect(opt.Callback)
    end
    
    function TabAPI:CreateToggle(opt)
        local t = Instance.new("TextButton", page)
        t.Size = UDim2.new(0.95, 0, 0, 36)
        t.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        t.Text = "  " .. opt.Name
        t.TextColor3 = Color3.fromRGB(180, 180, 180)
        t.TextXAlignment = Enum.TextXAlignment.Left
        t.TextSize = 12
        Instance.new("UICorner", t).CornerRadius = UDim.new(0, 6)
        t.LayoutOrder = GetOrder()
        AddHoverPulse(t, 1.02)
        local switch = CreateToggleSwitch(t, 1, 0.5, opt.Default or false, opt.Callback)
        t.MouseButton1Click:Connect(function() switch.SetState(not switch.GetState) end)
    end
    
    function TabAPI:CreateSlider(opt)
        local f = Instance.new("Frame", page)
        f.Size = UDim2.new(0.95, 0, 0, 55)
        f.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
        f.LayoutOrder = GetOrder()
        local label = Instance.new("TextLabel", f)
        label.Size = UDim2.new(1, -15, 0, 22)
        label.Position = UDim2.new(0, 10, 0, 5)
        label.BackgroundTransparency = 1
        label.Text = opt.Name .. ": " .. tostring(opt.Default)
        label.TextColor3 = Color3.new(1, 1, 1)
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextSize = 11
        local sbg = Instance.new("Frame", f)
        sbg.Size = UDim2.new(0.9, 0, 0, 6)
        sbg.Position = UDim2.new(0.05, 0, 0.7, 0)
        sbg.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        Instance.new("UICorner", sbg).CornerRadius = UDim.new(1, 0)
        local fill = Instance.new("Frame", sbg)
        fill.Size = UDim2.new((opt.Default - opt.Min) / (opt.Max - opt.Min), 0, 1, 0)
        fill.BackgroundColor3 = ACCENT
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
        local val = opt.Default
        local dragging = false
        local function update(input)
            local p = math.clamp((input.Position.X - sbg.AbsolutePosition.X) / sbg.AbsoluteSize.X, 0, 1)
            val = math.floor(opt.Min + (opt.Max - opt.Min) * p)
            fill.Size = UDim2.new(p, 0, 1, 0)
            label.Text = opt.Name .. ": " .. tostring(val)
            opt.Callback(val)
        end
        sbg.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                update(i)
            end
        end)
        UIS.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
        UIS.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end
        end)
    end
    
    function TabAPI:CreateSection(title)
        local s = Instance.new("Frame", page)
        s.Size = UDim2.new(0.95, 0, 0, 28)
        s.BackgroundTransparency = 1
        s.LayoutOrder = GetOrder()
        local lbl = Instance.new("TextLabel", s)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.Text = title:upper()
        lbl.TextColor3 = ACCENT
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 10
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.BackgroundTransparency = 1
    end
    
    return TabAPI
end

