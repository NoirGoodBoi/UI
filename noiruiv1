local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Debris = game:GetService("Debris")

local NoirUI = {}

function NoirUI:CreateWindow(settings)

    local old = game.CoreGui:FindFirstChild("NoirUI")
    if old then old:Destroy() end

    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "NoirUI"

    local ACCENT = settings.Accent or Color3.fromRGB(170,85,255)

    -- MAIN
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0,340,0,280)
    Main.Position = UDim2.new(0.5,-170,0.5,-140)
    Main.BackgroundColor3 = Color3.fromRGB(10,10,10)
    Instance.new("UICorner", Main)

    -- TITLE
    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1,0,0,30)
    Title.BackgroundTransparency = 1
    Title.Text = settings.Name or "Noir UI"
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16

    -- TAB BAR
    local TabBar = Instance.new("Frame", Main)
    TabBar.Size = UDim2.new(1,0,0,30)
    TabBar.Position = UDim2.new(0,0,0,30)
    TabBar.BackgroundTransparency = 1

    local TabList = Instance.new("UIListLayout", TabBar)
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.Padding = UDim.new(0,6)

    -- CONTENT AREA
    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1,0,1,-60)
    Content.Position = UDim2.new(0,0,0,60)
    Content.BackgroundTransparency = 1

    local Tabs = {}
    local ActiveTab = nil

    -- CREATE TAB
    function NoirUI:CreateTab(name)

        local TabFrame = Instance.new("Frame", Content)
        TabFrame.Size = UDim2.new(1,0,1,0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = false

        local Container = Instance.new("ScrollingFrame", TabFrame)
        Container.Size = UDim2.new(1,0,1,0)
        Container.BackgroundTransparency = 1
        Container.ScrollBarThickness = 3
        Container.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local Layout = Instance.new("UIListLayout", Container)
        Layout.Padding = UDim.new(0,6)

        -- TAB BUTTON
        local TabBtn = Instance.new("TextButton", TabBar)
        TabBtn.Size = UDim2.new(0,80,1,0)
        TabBtn.Text = name
        TabBtn.BackgroundColor3 = Color3.fromRGB(25,25,25)
        TabBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", TabBtn)

        Tabs[name] = TabFrame

        TabBtn.MouseButton1Click:Connect(function()
            if ActiveTab then
                Tabs[ActiveTab].Visible = false
            end
            ActiveTab = name
            TabFrame.Visible = true
        end)

        -- auto first tab
        if not ActiveTab then
            ActiveTab = name
            TabFrame.Visible = true
        end

        -- ELEMENT API inside tab
        local TabAPI = {}

        function TabAPI:CreateButton(opt)
            local b = Instance.new("TextButton", Container)
            b.Size = UDim2.new(1,0,0,35)
            b.Text = opt.Name
            b.BackgroundColor3 = Color3.fromRGB(25,25,25)
            b.TextColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", b)

            b.MouseButton1Click:Connect(function()
                if opt.Callback then opt.Callback() end
            end)
        end

        function TabAPI:CreateToggle(opt)
            local b = Instance.new("TextButton", Container)
            b.Size = UDim2.new(1,0,0,35)
            b.BackgroundColor3 = Color3.fromRGB(25,25,25)
            b.TextColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", b)

            local state = false
            b.Text = opt.Name..": OFF"

            b.MouseButton1Click:Connect(function()
                state = not state
                b.Text = opt.Name..": "..(state and "ON" or "OFF")
                if opt.Callback then opt.Callback(state) end
            end)
        end

        function TabAPI:CreateTextBox(opt)
            local box = Instance.new("TextBox", Container)
            box.Size = UDim2.new(1,0,0,35)
            box.BackgroundColor3 = Color3.fromRGB(25,25,25)
            box.TextColor3 = Color3.new(1,1,1)
            box.PlaceholderText = opt.Placeholder or "Enter..."
            Instance.new("UICorner", box)

            box.FocusLost:Connect(function()
                if opt.Callback then opt.Callback(box.Text) end
            end)
        end

        function TabAPI:CreateLabel(text)
            local l = Instance.new("TextLabel", Container)
            l.Size = UDim2.new(1,0,0,20)
            l.BackgroundTransparency = 1
            l.TextColor3 = Color3.fromRGB(200,200,200)
            l.Text = text
            l.TextXAlignment = Enum.TextXAlignment.Left
        end

        function TabAPI:CreateSlider(opt)
            local min,max = opt.Min or 0, opt.Max or 100
            local step = opt.Step or 1
            local value = opt.Default or min

            local holder = Instance.new("Frame", Container)
            holder.Size = UDim2.new(1,0,0,40)
            holder.BackgroundTransparency = 1

            local label = Instance.new("TextLabel", holder)
            label.Size = UDim2.new(1,0,0,18)
            label.BackgroundTransparency = 1
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.TextColor3 = Color3.new(1,1,1)
            label.Text = opt.Name..": "..value

            local bar = Instance.new("Frame", holder)
            bar.Position = UDim2.new(0,0,0,22)
            bar.Size = UDim2.new(1,0,0,8)
            bar.BackgroundColor3 = Color3.fromRGB(30,30,30)
            Instance.new("UICorner", bar)

            local fill = Instance.new("Frame", bar)
            fill.Size = UDim2.new((value-min)/(max-min),0,1,0)
            fill.BackgroundColor3 = ACCENT
            Instance.new("UICorner", fill)

            local dragging = false

            bar.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                end
            end)

            UIS.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then

                    local x = math.clamp(
                        (i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X,
                        0,1
                    )

                    value = math.floor((min + (max-min)*x)/step + 0.5)*step

                    fill.Size = UDim2.new((value-min)/(max-min),0,1,0)
                    label.Text = opt.Name..": "..value

                    if opt.Callback then opt.Callback(value) end
                end
            end)
        end

        return TabAPI
    end

    return NoirUI
end

return NoirUI
