    local KeyUI = nil
    
    local function StartUI()
        NoirUI.IsKeySolved = true
        Main.Visible = true
    end

    if settings.KeySystem then
        local KS = settings.KeySettings or {}
        local KeyPath = (KS.FileName or "NoirKey") .. ".json"
        
        -- Hàm kiểm tra key đúng hay sai
        local function IsCorrectKey(input)
            local validKeys = type(KS.Key) == "table" and KS.Key or {KS.Key}
            for _, k in pairs(validKeys) do
                if input == k then return true end
            end
            return false
        end

        -- Kiểm tra key đã lưu trong máy chưa
        if KS.SaveKey and isfile and isfile(KeyPath) then
            if IsCorrectKey(readfile(KeyPath)) then
                StartUI()
            end
        end

        if not NoirUI.IsKeySolved then
            KeyUI = Instance.new("Frame", ScreenGui)
            KeyUI.Size = UDim2.new(0, 320, 0, 200)
