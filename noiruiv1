                state = not state
                ToggleBtn.TextColor3 = state and ACCENT_COLOR or Color3.fromRGB(180, 180, 180)
                ToggleIndicator.BackgroundColor3 = state and ACCENT_COLOR or Color3.fromRGB(40, 40, 40)
                opt.Callback(state)
            end)
        end

        -- Component: Slider (Thanh trượt)
        function Tab:CreateSlider(opt)
            local SliderFrame = Instance.new("Frame", ScrollPage)
            SliderFrame.Size = UDim2.new(0.95, 0, 0, 45)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            SliderFrame.LayoutOrder = GetOrder()
            Instance.new("UICorner", SliderFrame)

            local sLabel = Instance.new("TextLabel", SliderFrame)
            sLabel.Size = UDim2.new(1, 0, 0, 20)
            sLabel.Position = UDim2.new(0, 12, 0, 2)
            sLabel.Text = opt.Name .. ": " .. opt.Default
            sLabel.TextColor3 = Color3.new(1, 1, 1)
            sLabel.BackgroundTransparency = 1
            sLabel.TextXAlignment = Enum.TextXAlignment.Left
            sLabel.Font = Enum.Font.GothamMedium

            local SliderBg = Instance.new("Frame", SliderFrame)
            SliderBg.Size = UDim2.new(0.9, 0, 0, 6)
            SliderBg.Position = UDim2.new(0.05, 0, 0.75, 0)
            SliderBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Instance.new("UICorner", SliderBg)

            local SliderFill = Instance.new("Frame", SliderBg)
            SliderFill.Size = UDim2.new(math.clamp((opt.Default - opt.Min) / (opt.Max - opt.Min), 0, 1), 0, 1, 0)
            SliderFill.BackgroundColor3 = ACCENT_COLOR
            Instance.new("UICorner", SliderFill)

            local isDragging = false
            local function UpdateSlider(input)
                local pos = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
                SliderFill.Size = UDim2.new(pos, 0, 1, 0)
                local value = math.floor(opt.Min + (opt.Max - opt.Min) * pos)
                sLabel.Text = opt.Name .. ": " .. value
                opt.Callback(value)
            end

            SliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = true
                    UpdateSlider(input)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(input)
                end
            end)
        end

        -- Component: TextBox (Ô nhập liệu)
        function Tab:CreateTextBox(opt)
            local BoxFrame = Instance.new("Frame", ScrollPage)
            BoxFrame.Size = UDim2.new(0.95, 0, 0, 35)
            BoxFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            BoxFrame.LayoutOrder = GetOrder()
            Instance.new("UICorner", BoxFrame)

            local Input = Instance.new("TextBox", BoxFrame)
