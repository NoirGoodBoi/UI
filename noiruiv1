-- // HÀM TWEEN CHUẨN
local function Tween(obj, props, time, style, direction, repeatCount, reverse, delay)
    style = style or Enum.EasingStyle.Quad
    direction = direction or Enum.EasingDirection.Out
    local tween = TweenService:Create(obj, TweenInfo.new(time or 0.2, style, direction, repeatCount or 0, reverse or false, delay or 0), props)
    tween:Play()
    return tween
end

-- // HÀM KÉO THẢ (có lưu vị trí float)
local FloatStartPos = nil
local function MakeDraggable(frame, isFloat)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if isFloat and FloatStartPos == nil then
                        FloatStartPos = frame.Position
                    end
                end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- // HOVER PULSE
local function AddHoverPulse(btn, scale)
    btn.MouseEnter:Connect(function()
        Tween(btn, { Size = UDim2.new(scale or 1, (btn.Size.X.Offset or 0), scale or 1, (btn.Size.Y.Offset or 0)) }, 0.15)
        if btn:FindFirstChild("UIStroke") then
            Tween(btn.UIStroke, { Transparency = 0 }, 0.1)
        end
    end)
    btn.MouseLeave:Connect(function()
        Tween(btn, { Size = UDim2.new(1, (btn.Size.X.Offset or 0), 1, (btn.Size.Y.Offset or 0)) }, 0.15)
        if btn:FindFirstChild("UIStroke") then
            Tween(btn.UIStroke, { Transparency = 1 }, 0.1)
        end
    end)
    btn.MouseButton1Click:Connect(function()
        Tween(btn, { Size = UDim2.new(0.95, (btn.Size.X.Offset or 0), 0.95, (btn.Size.Y.Offset or 0)) }, 0.05)
        task.wait(0.05)
        Tween(btn, { Size = UDim2.new(scale or 1, (btn.Size.X.Offset or 0), scale or 1, (btn.Size.Y.Offset or 0)) }, 0.05)
    end)
end

-- // TẠO SLIDING SWITCH (iOS Style)
local function CreateToggleSwitch(parent, x, y, default, callback)
    local switch = Instance.new("Frame", parent)
    switch.Size = UDim2.new(0, 40, 0, 22)
    switch.Position = UDim2.new(x or 1, -45, y or 0.5, -11)
    switch.BackgroundColor3 = default and ACCENT or Color3.fromRGB(60, 60, 60)
    Instance.new("UICorner", switch).CornerRadius = UDim.new(1, 0)
    
    local dot = Instance.new("Frame", switch)
    dot.Size = UDim2.new(0, 18, 0, 18)
    dot.Position = default and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    dot.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    
    local state = default or false
    switch.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            state = not state
            Tween(switch, { BackgroundColor3 = state and ACCENT or Color3.fromRGB(60, 60, 60) }, 0.15)
            Tween(dot, { Position = state and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9) }, 0.15)
            if callback then callback(state) end
        end
    end)
    return { SetState = function(s)
        state = s
        switch.BackgroundColor3 = state and ACCENT or Color3.fromRGB(60, 60, 60)
        dot.Position = state and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    end }
end

