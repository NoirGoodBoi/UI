local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")

local NoirUI = { Notifications = {} }

-- [[ HÀM KÉO THẢ ]]
local function MakeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function NoirUI:CreateWindow(settings)
    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "NoirUI"; ScreenGui.ResetOnSpawn = false

    local ACCENT = settings.Accent or Color3.fromRGB(170, 85, 255)
    
    -- MAIN FRAME
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 420, 0, 300)
    Main.Position = UDim2.new(0.5, -210, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    Main.ClipsDescendants = true
    Instance.new("UICorner", Main)
    local Stroke = Instance.new("UIStroke", Main); Stroke.Thickness = 2
    
    -- Hiệu ứng RGB cho Stroke
    task.spawn(function()
        while Main and Main.Parent do
            for i = 0, 1, 0.01 do
                if not Main or not Main.Parent then break end
                Stroke.Color = Color3.fromHSV(i, 0.8, 1); task.wait(0.04)
            end
        end
    end)

    -- SIDEBAR & CONTAINER
    local SidebarArea = Instance.new("Frame", Main)
    SidebarArea.Size = UDim2.new(0, 110, 1, -50); SidebarArea.Position = UDim2.new(0, 5, 0, 40); SidebarArea.BackgroundTransparency = 1

    local TabScroll = Instance.new("ScrollingFrame", SidebarArea)
    TabScroll.Size = UDim2.new(1, 0, 1, -55); TabScroll.BackgroundTransparency = 1; TabScroll.ScrollBarThickness = 0; TabScroll.AutomaticCanvasSize = "Y"
    Instance.new("UIListLayout", TabScroll).Padding = UDim.new(0, 5)

    local UserArea = Instance.new("Frame", SidebarArea)
    UserArea.Size = UDim2.new(1, 0, 0, 50); UserArea.Position = UDim2.new(0, 0, 1, -45); UserArea.BackgroundTransparency = 1
    
    local AvatarImg = Instance.new("ImageLabel", UserArea)
    AvatarImg.Size = UDim2.new(0, 42, 0, 42); AvatarImg.Position = UDim2.new(0.5, -21, 0, 0)
    AvatarImg.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
    Instance.new("UICorner", AvatarImg).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", AvatarImg).Color = ACCENT

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -125, 1, -50); Container.Position = UDim2.new(0, 120, 0, 40); Container.BackgroundTransparency = 1

    -- TITLE
    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 40); Title.Position = UDim2.new(0, 15, 0, 0); Title.BackgroundTransparency = 1
    Title.Text = settings.Name or "NOIR HUB"; Title.TextColor3 = Color3.new(1,1,1); Title.Font = "GothamBold"; Title.TextSize = 14; Title.TextXAlignment = "Left"

    -- ANIMATION OPEN/CLOSE
    local function ToggleUI(state)
        if state then
            Main.Visible = true
            Main:TweenSize(UDim2.new(0, 420, 0, 300), "Out", "Back", 0.4, true)
            TweenService:Create(Main, TweenInfo.new(0.4), {GroupTransparency = 0}):Play()
        else
            Main:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.4, true)
            task.wait(0.4)
            Main.Visible = false
        end
    end

    -- FLOATING ICON
    local ToggleBtn = Instance.new("TextButton", ScreenGui)
    ToggleBtn.Size = UDim2.new(0, 45, 0, 45); ToggleBtn.Position = UDim2.new(0, 15, 0.5, -22); ToggleBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    ToggleBtn.Text = settings.Icon or "N"; ToggleBtn.TextColor3 = ACCENT; ToggleBtn.TextSize = 18
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(1, 0); Instance.new("UIStroke", ToggleBtn).Color = ACCENT
    MakeDraggable(ToggleBtn)
    
    local isOpen = true
    ToggleBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        ToggleUI(isOpen)
    end)

    local Window = {}

    function Window:CreateTab(name)
        local TabBtn = Instance.new("TextButton", TabScroll)
        TabBtn.Size = UDim2.new(1, -5, 0, 32); TabBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        TabBtn.Text = name; TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150); TabBtn.Font = "GothamMedium"; TabBtn.TextSize = 11; Instance.new("UICorner", TabBtn)

        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.Visible = false; Page.ScrollBarThickness = 1; Page.AutomaticCanvasSize = "Y"
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8); Page.UIListLayout.HorizontalAlignment = "Center"

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(TabScroll:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Color3.fromRGB(150, 150, 150) end end
            Page.Visible = true; TabBtn.TextColor3 = ACCENT
        end)

        if #TabScroll:GetChildren() == 2 then Page.Visible = true; TabBtn.TextColor3 = ACCENT end

        local Tab = {}

        function Tab:CreateButton(opt)
            local b = Instance.new("TextButton", Page); b.Size = UDim2.new(0.95, 0, 0, 35); b.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            b.Text = opt.Name; b.TextColor3 = Color3.new(1,1,1); b.Font = "GothamMedium"; b.TextSize = 12; Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(opt.Callback)
        end

        function Tab:CreateToggle(opt)
            local s = false
            local t = Instance.new("TextButton", Page); t.Size = UDim2.new(0.95, 0, 0, 35); t.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            t.Text = opt.Name .. " [OFF]"; t.TextColor3 = Color3.fromRGB(180, 180, 180); t.TextSize = 12; Instance.new("UICorner", t)
            t.MouseButton1Click:Connect(function()
                s = not s
                t.Text = opt.Name .. (s and " [ON]" or " [OFF]")
                t.TextColor3 = s and ACCENT or Color3.fromRGB(180, 180, 180)
                opt.Callback(s)
            end)
        end

        function Tab:CreateSlider(opt)
            local f = Instance.new("Frame", Page); f.Size = UDim2.new(0.95, 0, 0, 45); f.BackgroundColor3 = Color3.fromRGB(22, 22, 22); Instance.new("UICorner", f)
            local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 20); l.Position = UDim2.new(0, 10, 0, 2); l.BackgroundTransparency = 1
            l.Text = opt.Name .. ": " .. opt.Default; l.TextColor3 = Color3.new(1,1,1); l.TextXAlignment = "Left"; l.TextSize = 11

            local sbg = Instance.new("Frame", f); sbg.Size = UDim2.new(0.9, 0, 0, 5); sbg.Position = UDim2.new(0.05, 0, 0.7, 0); sbg.BackgroundColor3 = Color3.fromRGB(40, 40, 40); Instance.new("UICorner", sbg)
            local fill = Instance.new("Frame", sbg); fill.Size = UDim2.new((opt.Default - opt.Min)/(opt.Max - opt.Min), 0, 1, 0); fill.BackgroundColor3 = ACCENT; Instance.new("UICorner", fill)
            
            local function update()
                local m = UIS:GetMouseLocation().X - sbg.AbsolutePosition.X
                local p = math.clamp(m / sbg.AbsoluteSize.X, 0, 1)
                local v = math.floor(opt.Min + (opt.Max - opt.Min) * p)
                fill.Size = UDim2.new(p, 0, 1, 0)
                l.Text = opt.Name .. ": " .. v
                opt.Callback(v)
            end

            sbg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    local con; con = UIS.InputChanged:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then update() end
                    end)
                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then con:Disconnect() end
                    end)
                    update()
                end
            end)
        end

        function Tab:CreateRunBox(opt)
            local f = Instance.new("Frame", Page); f.Size = UDim2.new(0.95, 0, 0, 35); f.BackgroundColor3 = Color3.fromRGB(18, 18, 18); Instance.new("UICorner", f)
            local i = Instance.new("TextBox", f); i.Size = UDim2.new(1, -55, 1, 0); i.Position = UDim2.new(0, 8, 0, 0); i.BackgroundTransparency = 1
            i.PlaceholderText = "Command..."; i.Text = ""; i.TextColor3 = Color3.new(1,1,1); i.TextXAlignment = "Left"; i.ClearTextOnFocus = false
            local r = Instance.new("TextButton", f); r.Size = UDim2.new(0, 45, 0, 25); r.Position = UDim2.new(1, -50, 0.5, -12.5); r.BackgroundColor3 = ACCENT
            r.Text = "RUN"; r.TextColor3 = Color3.new(1,1,1); r.Font = "GothamBold"; Instance.new("UICorner", r)
            r.MouseButton1Click:Connect(function() if i.Text ~= "" then opt.Callback(i.Text) end end)
        end

        return Tab
    end

    function NoirUI:Notify(title, msg)
        local n = Instance.new("Frame", ScreenGui); n.Size = UDim2.new(0, 220, 0, 65); n.Position = UDim2.new(1, 20, 0.8, 0)
        n.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", n); Instance.new("UIStroke", n).Color = ACCENT
        local t = Instance.new("TextLabel", n); t.Size = UDim2.new(1, -10, 0, 20); t.Position = UDim2.new(0, 10, 0, 5); t.Text = title; t.TextColor3 = ACCENT; t.BackgroundTransparency = 1; t.Font = "GothamBold"
        local m = Instance.new("TextLabel", n); m.Size = UDim2.new(1, -15, 0, 40); m.Position = UDim2.new(0, 10, 0, 22); m.Text = msg; m.TextColor3 = Color3.new(1,1,1); m.BackgroundTransparency = 1; m.TextWrapped = true; m.TextXAlignment = "Left"; m.TextYAlignment = "Top"
        
        for i, old in ipairs(NoirUI.Notifications) do TweenService:Create(old, TweenInfo.new(0.3), {Position = UDim2.new(1, -240, 0.8, -(i * 75))}):Play() end
        table.insert(NoirUI.Notifications, 1, n)
        TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -240, 0.8, 0)}):Play()
        task.delay(4, function()
            TweenService:Create(n, TweenInfo.new(0.5), {Position = UDim2.new(1, 20, n.Position.Y.Scale, n.Position.Y.Offset), BackgroundTransparency = 1}):Play()
            task.wait(0.5); for i, val in ipairs(NoirUI.Notifications) do if val == n then table.remove(NoirUI.Notifications, i) break end end; n:Destroy()
        end)
    end

    return Window
end

return NoirUI
