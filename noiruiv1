        -- Component: Dropdown (Danh sách chọn)
        function Tab:CreateDropdown(opt)
            local DropFrame = Instance.new("Frame", ScrollPage)
            DropFrame.Size = UDim2.new(0.95, 0, 0, 35)
            DropFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            DropFrame.ClipsDescendants = true
            DropFrame.LayoutOrder = GetOrder()
            Instance.new("UICorner", DropFrame)

            local DropBtn = Instance.new("TextButton", DropFrame)
            DropBtn.Size = UDim2.new(1, 0, 0, 35)
            DropBtn.BackgroundTransparency = 1
            DropBtn.Text = "  " .. opt.Name .. " : " .. (opt.Default or opt.Options[1])
            DropBtn.TextColor3 = Color3.new(1, 1, 1)
            DropBtn.TextXAlignment = Enum.TextXAlignment.Left
            DropBtn.Font = Enum.Font.GothamMedium

            local ItemList = Instance.new("Frame", DropFrame)
            ItemList.Size = UDim2.new(1, 0, 0, #opt.Options * 30)
            ItemList.Position = UDim2.new(0, 0, 0, 35)
            ItemList.BackgroundTransparency = 1
            local DropLayout = Instance.new("UIListLayout", ItemList)

            local isDropped = false
            DropBtn.MouseButton1Click:Connect(function()
                isDropped = not isDropped
                local targetSize = isDropped and UDim2.new(0.95, 0, 0, 35 + ItemList.Size.Y.Offset) or UDim2.new(0.95, 0, 0, 35)
                TweenService:Create(DropFrame, TweenInfo.new(0.3), {Size = targetSize}):Play()
            end)

            for _, val in pairs(opt.Options) do
                local Item = Instance.new("TextButton", ItemList)
                Item.Size = UDim2.new(1, 0, 0, 30)
                Item.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
                Item.Text = val
                Item.TextColor3 = Color3.fromRGB(200, 200, 200)
                Item.Font = Enum.Font.Gotham
                
                Item.MouseButton1Click:Connect(function()
                    isDropped = false
                    DropBtn.Text = "  " .. opt.Name .. " : " .. val
                    TweenService:Create(DropFrame, TweenInfo.new(0.3), {Size = UDim2.new(0.95, 0, 0, 35)}):Play()
                    opt.Callback(val)
                end)
            end
        end

        -- Component: ColorPicker (Chọn màu)
        function Tab:CreateColorPicker(opt)
            local SelectedColor = opt.Default or ACCENT_COLOR
            local h, s, v = SelectedColor:ToHSV()
            local isOpen = false

            local ColorFrame = Instance.new("Frame", ScrollPage)
            ColorFrame.Size = UDim2.new(0.95, 0, 0, 35)
            ColorFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            ColorFrame.ClipsDescendants = true
            ColorFrame.LayoutOrder = GetOrder()
            Instance.new("UICorner", ColorFrame)

            local cLabel = Instance.new("TextLabel", ColorFrame)
            cLabel.Size = UDim2.new(1, 0, 0, 35)
            cLabel.Position = UDim2.new(0, 12, 0, 0)
            cLabel.Text = opt.Name
            cLabel.TextColor3 = Color3.new(1, 1, 1)
            cLabel.BackgroundTransparency = 1
            cLabel.TextXAlignment = Enum.TextXAlignment.Left
            cLabel.Font = Enum.Font.GothamMedium

            local Preview = Instance.new("TextButton", ColorFrame)
            Preview.Size = UDim2.new(0, 40, 0, 18)
            Preview.Position = UDim2.new(1, -50, 0, 8.5)
            Preview.BackgroundColor3 = SelectedColor
            Preview.Text = ""
            Instance.new("UICorner", Preview)

            Preview.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                local targetSize = isOpen and UDim2.new(0.95, 0, 0, 160) or UDim2.new(0.95, 0, 0, 35)
                TweenService:Create(ColorFrame, TweenInfo.new(0.3), {Size = targetSize}):Play()
            end)

            -- Ô chọn độ bão hòa và độ sáng (S/V)
            local Canvas = Instance.new("ImageButton", ColorFrame)
            Canvas.Size = UDim2.new(0, 100, 0, 100)
            Canvas.Position = UDim2.new(0, 10, 0, 45)
            Canvas.Image = "rbxassetid://4155801252"
            Canvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

            -- Thanh chọn tông màu (Hue)
            local HueBar = Instance.new("ImageButton", ColorFrame)
            HueBar.Size = UDim2.new(0, 20, 0, 100)
            HueBar.Position = UDim2.new(0, 120, 0, 45)
            HueBar.Image = "rbxassetid://3641079629"

            local function UpdateColor()
                local finalCol = Color3.fromHSV(h, s, v)
                Preview.BackgroundColor3 = finalCol
                Canvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                opt.Callback(finalCol)
            end

            Canvas.MouseButton1Down:Connect(function()
                local connection
                connection = RunService.RenderStepped:Connect(function()
                    s = math.clamp((UserInputService:GetMouseLocation().X - Canvas.AbsolutePosition.X) / Canvas.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((UserInputService:GetMouseLocation().Y - Canvas.AbsolutePosition.Y - 36) / Canvas.AbsoluteSize.Y, 0, 1)
                    UpdateColor()
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        if connection then connection:Disconnect() end
                    end
                end)
            end)

            HueBar.MouseButton1Down:Connect(function()
                local connection
                connection = RunService.RenderStepped:Connect(function()
                    h = 1 - math.clamp((UserInputService:GetMouseLocation().Y - HueBar.AbsolutePosition.Y - 36) / HueBar.AbsoluteSize.Y, 0, 1)
                    UpdateColor()
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        if connection then connection:Disconnect() end
                    end
                end)
            end)
        end

        -- Component: RunBox (Chạy code nhanh)
        function Tab:CreateRunBox(opt)
            local RunFrame = Instance.new("Frame", ScrollPage)
            RunFrame.Size = UDim2.new(0.95, 0, 0, 38)
            RunFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            RunFrame.LayoutOrder = GetOrder()
            Instance.new("UICorner", RunFrame)

            local CodeInput = Instance.new("TextBox", RunFrame)
            CodeInput.Size = UDim2.new(1, -65, 1, 0)
            CodeInput.Position = UDim2.new(0, 10, 0, 0)
            CodeInput.BackgroundTransparency = 1
            CodeInput.PlaceholderText = opt.Placeholder or "Nhập Lua code hoặc lệnh..."
            CodeInput.TextColor3 = Color3.new(1, 1, 1)
            CodeInput.TextXAlignment = Enum.TextXAlignment.Left
            CodeInput.Font = Enum.Font.Code
            CodeInput.TextSize = 12

            local RunBtn = Instance.new("TextButton", RunFrame)
            RunBtn.Size = UDim2.new(0, 50, 0, 26)
            RunBtn.Position = UDim2.new(1, -55, 0.5, -13)
            RunBtn.BackgroundColor3 = ACCENT_COLOR
            RunBtn.Text = "RUN"
            RunBtn.TextColor3 = Color3.new(1, 1, 1)
            RunBtn.Font = Enum.Font.GothamBold
            Instance.new("UICorner", RunBtn)

            RunBtn.MouseButton1Click:Connect(function()
                local code = CodeInput.Text
                if code:sub(1, 1) == "." then
                    -- Xử lý lệnh nhanh nếu bắt đầu bằng .
                    local args = code:sub(2):split(" ")
                    if args[1] == "speed" then
                        Players.LocalPlayer.Character.Humanoid.WalkSpeed = tonumber(args[2]) or 16
                    end
                else
                    -- Chạy script trực tiếp
                    local success, err = pcall(function()
                        loadstring(code)()
                    end)
                    if not success then warn("Lỗi chạy script: " .. err) end
                end
            end)
        end

        return Tab
    end

    return Window
end

return NoirUI
