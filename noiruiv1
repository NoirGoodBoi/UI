            local KeyBtn = Instance.new("TextButton", KeyUI)
            KeyBtn.Size = UDim2.new(0.8, 0, 0, 35)
            KeyBtn.Position = UDim2.new(0.1, 0, 0.7, 0)
            KeyBtn.BackgroundColor3 = ACCENT_COLOR
            KeyBtn.Text = "XÁC NHẬN"
            KeyBtn.TextColor3 = Color3.new(1, 1, 1)
            KeyBtn.Font = Enum.Font.GothamBold
            Instance.new("UICorner", KeyBtn)

            KeyBtn.MouseButton1Click:Connect(function()
                if IsCorrectKey(KeyInput.Text) then
