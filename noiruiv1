local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Debris = game:GetService("Debris")

local NoirUI = {}

function NoirUI:CreateWindow(settings)

    local old = game.CoreGui:FindFirstChild("NoirUI")
    if old then old:Destroy() end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "NoirUI"
    ScreenGui.Parent = game.CoreGui

    local ACCENT = settings.Accent or Color3.fromRGB(170,85,255)
    local SettingsMode = false

    local Blur = Instance.new("BlurEffect", game.Lighting)
    Blur.Size = 0
    TweenService:Create(Blur, TweenInfo.new(0.3), {Size = 12}):Play()

    local Main = Instance.new("Frame")
    Main.Parent = ScreenGui
    Main.Size = UDim2.new(0,320,0,260)
    Main.Position = UDim2.new(0.5,-160,0.5,-130)
    Main.BackgroundColor3 = Color3.fromRGB(8,8,8)
    Main.BackgroundTransparency = 1
    Instance.new("UICorner", Main)

    TweenService:Create(Main, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()

    local SettingsFrame = Instance.new("Frame")
    SettingsFrame.Parent = ScreenGui
    SettingsFrame.Size = Main.Size
    SettingsFrame.Position = Main.Position
    SettingsFrame.BackgroundColor3 = Color3.fromRGB(8,8,8)
    SettingsFrame.Visible = false
    Instance.new("UICorner", SettingsFrame)

    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Thickness = 2

    local Glow = Instance.new("UIStroke", Main)
    Glow.Thickness = 6
    Glow.Transparency = 0.7

    task.spawn(function()
        while true do
            for i = 0,1,0.01 do
                local c = Color3.fromHSV(i,1,1)
                Stroke.Color = c
                Glow.Color = c
                task.wait()
            end
        end
    end)

    local function PlaySound()
        if not settings.SoundId then return end
        local s = Instance.new("Sound")
        s.SoundId = settings.SoundId
        s.Volume = 1
        s.Parent = game:GetService("SoundService")
        s:Play()
        Debris:AddItem(s,2)
    end

    local function Burst(parent)
        if not settings.IconEffect then return end

        for i = 1,8 do
            local d = Instance.new("Frame")
            d.Size = UDim2.new(0,4,0,4)
            d.BackgroundColor3 = ACCENT
            d.BorderSizePixel = 0
            d.Parent = parent

            local a = (i/8)*math.pi*2
            d.Position = UDim2.new(0.5,0,0.5,0)

            TweenService:Create(d,TweenInfo.new(0.4),{
                Position = UDim2.new(0.5+math.cos(a)*0.2,0,0.5+math.sin(a)*0.2,0),
                BackgroundTransparency = 1
            }):Play()

            Debris:AddItem(d,0.5)
        end
    end

    local function Drag(obj)
        local dragging,start,pos

        obj.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                start = i.Position
                pos = obj.Position
            end
        end)

        obj.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)

        UIS.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - start
                obj.Position = UDim2.new(pos.X.Scale,pos.X.Offset+d.X,pos.Y.Scale,pos.Y.Offset+d.Y)
            end
        end)
    end

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1,0,0,35)
    Title.BackgroundTransparency = 1
    Title.Text = settings.Name or "Noir UI"
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16

    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1,-10,1,-40)
    Container.Position = UDim2.new(0,5,0,35)
    Container.BackgroundTransparency = 1
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.ScrollBarThickness = 3

    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0,6)

    local SettingsContainer = Instance.new("Frame", SettingsFrame)
    SettingsContainer.Size = UDim2.new(1,0,1,0)
    SettingsContainer.BackgroundTransparency = 1

    local Window = {}

    function Window:CreateButton(opt)
        local parent = (opt.Page=="Settings") and SettingsContainer or Container

        local b = Instance.new("TextButton", parent)
        b.Size = UDim2.new(1,0,0,35)
        b.Text = opt.Name
        b.BackgroundColor3 = Color3.fromRGB(20,20,20)
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b)

        b.MouseButton1Click:Connect(function()
            PlaySound()
            Burst(b)
            if opt.Callback then opt.Callback() end
        end)
    end

    function Window:CreateToggle(opt)
        local parent = (opt.Page=="Settings") and SettingsContainer or Container

        local b = Instance.new("TextButton", parent)
        b.Size = UDim2.new(1,0,0,35)
        b.BackgroundColor3 = Color3.fromRGB(20,20,20)
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b)

        local s = false
        b.Text = opt.Name..": OFF"

        b.MouseButton1Click:Connect(function()
            s = not s
            b.Text = opt.Name..": "..(s and "ON" or "OFF")
            if opt.Callback then opt.Callback(s) end
        end)
    end

    function Window:CreateTextBox(opt)
        local parent = (opt.Page=="Settings") and SettingsContainer or Container

        local box = Instance.new("TextBox", parent)
        box.Size = UDim2.new(1,0,0,35)
        box.BackgroundColor3 = Color3.fromRGB(20,20,20)
        box.TextColor3 = Color3.new(1,1,1)
        box.PlaceholderText = opt.Placeholder or "Enter..."
        Instance.new("UICorner", box)

        box.FocusLost:Connect(function()
            if opt.Callback then opt.Callback(box.Text) end
        end)
    end

    function Window:CreateLabel(text, page)
        local parent = (page=="Settings") and SettingsContainer or Container

        local l = Instance.new("TextLabel", parent)
        l.Size = UDim2.new(1,0,0,25)
        l.BackgroundTransparency = 1
        l.Text = text
        l.TextColor3 = Color3.fromRGB(200,200,200)
        l.Font = Enum.Font.Gotham
        l.TextSize = 13
    end

    function Window:CreateSlider(opt)
        local parent = (opt.Page=="Settings") and SettingsContainer or Container

        local min = opt.Min or 0
        local max = opt.Max or 100
        local value = opt.Default or min

        local holder = Instance.new("Frame", parent)
        holder.Size = UDim2.new(1,0,0,40)
        holder.BackgroundTransparency = 1

        local label = Instance.new("TextLabel", holder)
        label.Size = UDim2.new(1,0,0,18)
        label.BackgroundTransparency = 1
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextColor3 = Color3.fromRGB(220,220,255)
        label.Font = Enum.Font.Gotham
        label.TextSize = 13
        label.Text = opt.Name..": "..value

        local bar = Instance.new("Frame", holder)
        bar.Position = UDim2.new(0,0,0,22)
        bar.Size = UDim2.new(1,0,0,8)
        bar.BackgroundColor3 = Color3.fromRGB(25,20,40)
        Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)

        local fill = Instance.new("Frame", bar)
        fill.Size = UDim2.new((value-min)/(max-min),0,1,0)
        fill.BackgroundColor3 = ACCENT
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

        local dragging = false

        bar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
            end
        end)

        bar.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)

        UIS.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local x = (i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
                x = math.clamp(x,0,1)

                value = math.floor(min + (max-min)*x)

                fill.Size = UDim2.new(x,0,1,0)
                label.Text = opt.Name..": "..value

                if opt.Callback then
                    opt.Callback(value)
                end
            end
        end)
    end

    function Window:Notify(t,txt,d)
        local g = Instance.new("ScreenGui", game.CoreGui)
        local f = Instance.new("Frame", g)

        f.Size = UDim2.new(0,240,0,60)
        f.Position = UDim2.new(1,-260,0.1,0)
        f.BackgroundColor3 = Color3.fromRGB(15,15,15)
        Instance.new("UICorner", f)

        local a = Instance.new("TextLabel", f)
        a.Size = UDim2.new(1,0,0,25)
        a.BackgroundTransparency = 1
        a.Text = t
        a.TextColor3 = Color3.new(1,1,1)

        local b = Instance.new("TextLabel", f)
        b.Size = UDim2.new(1,0,0,25)
        b.Position = UDim2.new(0,0,0,25)
        b.BackgroundTransparency = 1
        b.Text = txt
        b.TextColor3 = ACCENT

        task.delay(d or 2,function()
            g:Destroy()
        end)
    end

    local Float = Instance.new("TextButton", ScreenGui)
    Float.Size = UDim2.new(0,40,0,40)
    Float.Position = UDim2.new(0,20,0.5,-20)
    Float.Text = "⚡"
    Float.BackgroundColor3 = Color3.fromRGB(10,10,10)
    Instance.new("UICorner", Float)

    Drag(Float)

    local visible = true

    Float.MouseButton1Click:Connect(function()
        PlaySound()
        Burst(Float)
        visible = not visible
        Main.Visible = visible
    end)

    local Gear = Instance.new("TextButton", ScreenGui)
    Gear.Size = UDim2.new(0,40,0,40)
    Gear.Position = UDim2.new(0,70,0.5,-20)
    Gear.Text = "⚙"
    Gear.BackgroundColor3 = Color3.fromRGB(10,10,10)
    Instance.new("UICorner", Gear)

    Drag(Gear)

    Gear.MouseButton1Click:Connect(function()
        SettingsMode = not SettingsMode
        Main.Visible = not SettingsMode
        SettingsFrame.Visible = SettingsMode
    end)

    return Window
end

return NoirUI
