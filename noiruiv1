local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")

local NoirUI = { Notifications = {} }

-- [[ HÀM KÉO THẢ ]]
local function MakeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function NoirUI:CreateWindow(settings)
    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "NoirUI"; ScreenGui.ResetOnSpawn = false
    
    local ACCENT = settings.Accent or Color3.fromRGB(170, 85, 255)
    local BG_TRANSPARENCY = settings.Transparency or 0
    
    -- MAIN FRAME
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 420, 0, 300); Main.Position = UDim2.new(0.5, -210, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10); Main.ClipsDescendants = true
    Main.BackgroundTransparency = BG_TRANSPARENCY
    Instance.new("UICorner", Main); local Stroke = Instance.new("UIStroke", Main); Stroke.Thickness = 2
    MakeDraggable(Main) 

    -- RAINBOW EFFECT
    task.spawn(function()
        while Main and Main.Parent do
            for i = 0, 1, 0.01 do
                if not Main or not Main.Parent then break end
                Stroke.Color = Color3.fromHSV(i, 0.8, 1); task.wait(0.04)
            end
        end
    end)

    -- [[ KEY SYSTEM ]]
    if settings.KeySystem then
        Main.Visible = false
        local KeyUI = Instance.new("Frame", ScreenGui)
        KeyUI.Size = UDim2.new(0, 300, 0, 160); KeyUI.Position = UDim2.new(0.5, -150, 0.5, -80)
        KeyUI.BackgroundColor3 = Color3.fromRGB(10, 10, 10); Instance.new("UICorner", KeyUI)
        local KStroke = Instance.new("UIStroke", KeyUI); KStroke.Thickness = 2
        MakeDraggable(KeyUI) 
        
        task.spawn(function()
            while KeyUI and KeyUI.Parent do
                for i = 0, 1, 0.01 do if not KeyUI or not KeyUI.Parent then break end KStroke.Color = Color3.fromHSV(i, 0.8, 1); task.wait(0.04) end
            end
        end)

        local KInput = Instance.new("TextBox", KeyUI)
        KInput.Size = UDim2.new(0.8, 0, 0, 35); KInput.Position = UDim2.new(0.1, 0, 0.35, 0); KInput.BackgroundColor3 = Color3.fromRGB(20, 20, 20); KInput.TextColor3 = Color3.new(1,1,1); KInput.PlaceholderText = "Nhập Key..."; KInput.Text = ""; Instance.new("UICorner", KInput)

        local KBtn = Instance.new("TextButton", KeyUI)
        KBtn.Size = UDim2.new(0.8, 0, 0, 35); KBtn.Position = UDim2.new(0.1, 0, 0.7, 0); KBtn.BackgroundColor3 = ACCENT; KBtn.Text = "XÁC NHẬN"; KBtn.Font = "GothamBold"; Instance.new("UICorner", KBtn)
        
        KBtn.MouseButton1Click:Connect(function()
            if KInput.Text == settings.Key then
                KeyUI:Destroy(); Main.Visible = true
                NoirUI:Notify("Thành công", "Đã mở khóa giao diện!")
            else
                KInput.Text = ""; KInput.PlaceholderText = "Sai Key rồi!"
            end
        end)
    end

    -- HEADER
    local Header = Instance.new("Frame", Main)
    Header.Size = UDim2.new(1, 0, 0, 40); Header.BackgroundTransparency = 1
    
    local Title = Instance.new("TextLabel", Header)
    Title.Size = UDim2.new(1, -120, 1, 0); Title.Position = UDim2.new(0, 15, 0, 0); Title.BackgroundTransparency = 1; Title.Text = settings.Name or "NOIR HUB"; Title.TextColor3 = Color3.new(1,1,1); Title.Font = "GothamBold"; Title.TextSize = 14; Title.TextXAlignment = "Left"

    local Btns = Instance.new("Frame", Header)
    Btns.Size = UDim2.new(0, 70, 1, 0); Btns.Position = UDim2.new(1, -75, 0, 0); Btns.BackgroundTransparency = 1
    local BtnList = Instance.new("UIListLayout", Btns); BtnList.FillDirection = "Horizontal"; BtnList.HorizontalAlignment = "Right"; BtnList.VerticalAlignment = "Center"; BtnList.Padding = UDim.new(0, 5)

    local function CreateTopBtn(txt, color, callback)
        local b = Instance.new("TextButton", Btns)
        b.Size = UDim2.new(0, 22, 0, 22); b.BackgroundColor3 = Color3.fromRGB(25, 25, 25); b.Text = txt; b.TextColor3 = color; b.Font = "GothamBold"; Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(callback)
    end

    -- XÓA UI (X)
    CreateTopBtn("X", Color3.fromRGB(255, 100, 100), function()
        local Conf = Instance.new("Frame", ScreenGui); Conf.Size = UDim2.new(0, 180, 0, 90); Conf.Position = UDim2.new(0.5, -90, 0.5, -45); Conf.BackgroundColor3 = Color3.fromRGB(20,20,20); Instance.new("UICorner", Conf); Conf.ZIndex = 100
        local t = Instance.new("TextLabel", Conf); t.Size = UDim2.new(1,0,0,40); t.Text = "Bạn có chắc chắn?"; t.TextColor3 = Color3.new(1,1,1); t.BackgroundTransparency = 1; t.ZIndex = 101; t.Font = "GothamBold"; t.TextSize = 12
        local y = Instance.new("TextButton", Conf); y.Size = UDim2.new(0.5,0,0,30); y.Position = UDim2.new(0,0,1,-30); y.Text = "Có"; y.BackgroundColor3 = Color3.fromRGB(150,50,50); y.ZIndex = 101; y.TextColor3 = Color3.new(1,1,1)
        local n = Instance.new("TextButton", Conf); n.Size = UDim2.new(0.5,0,0,30); n.Position = UDim2.new(0.5,0,1,-30); n.Text = "Không"; n.BackgroundColor3 = Color3.fromRGB(40,40,40); n.ZIndex = 101; n.TextColor3 = Color3.new(1,1,1)
        y.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
        n.MouseButton1Click:Connect(function() Conf:Destroy() end)
    end)

    -- THU NHỎ (-)
    local isMin = false
    CreateTopBtn("-", Color3.fromRGB(255, 200, 50), function()
        isMin = not isMin
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = isMin and UDim2.new(0, 420, 0, 40) or UDim2.new(0, 420, 0, 300)}):Play()
    end)

    -- NÚT TOGGLE (Hỗ trợ Text hoặc Image ID)
    local ToggleBtn = Instance.new("TextButton", ScreenGui)
    ToggleBtn.Size = UDim2.new(0, 45, 0, 45); ToggleBtn.Position = UDim2.new(0, 15, 0.5, -22); ToggleBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15); ToggleBtn.Text = ""
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(1,0); local TStroke = Instance.new("UIStroke", ToggleBtn); TStroke.Color = ACCENT; TStroke.Thickness = 2
    MakeDraggable(ToggleBtn)

    if type(settings.Icon) == "number" or tonumber(settings.Icon) then
        local IconImg = Instance.new("ImageLabel", ToggleBtn)
        IconImg.Size = UDim2.new(0, 25, 0, 25); IconImg.Position = UDim2.new(0.5, -12, 0.5, -12); IconImg.BackgroundTransparency = 1; IconImg.Image = "rbxassetid://" .. tostring(settings.Icon); IconImg.ImageColor3 = ACCENT
    else
        ToggleBtn.Text = settings.Icon or "N"; ToggleBtn.TextColor3 = ACCENT; ToggleBtn.TextSize = 18; ToggleBtn.Font = "GothamBold"
    end
    ToggleBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

    -- SIDEBAR & CONTAINER
    local SidebarArea = Instance.new("Frame", Main)
    SidebarArea.Size = UDim2.new(0, 110, 1, -50); SidebarArea.Position = UDim2.new(0, 5, 0, 40); SidebarArea.BackgroundTransparency = 1
    local TabScroll = Instance.new("ScrollingFrame", SidebarArea)
    TabScroll.Size = UDim2.new(1, 0, 1, -55); TabScroll.BackgroundTransparency = 1; TabScroll.ScrollBarThickness = 0; TabScroll.AutomaticCanvasSize = "Y"
    Instance.new("UIListLayout", TabScroll).Padding = UDim.new(0, 5)

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -125, 1, -50); Container.Position = UDim2.new(0, 120, 0, 40); Container.BackgroundTransparency = 1

    local Window = {}
    function Window:CreateTab(name, iconID)
        local TabBtn = Instance.new("TextButton", TabScroll)
        TabBtn.Size = UDim2.new(1, -5, 0, 32); TabBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20); TabBtn.Text = (iconID and "      " or "") .. name; TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150); TabBtn.Font = "GothamMedium"; TabBtn.TextSize = 11; TabBtn.TextXAlignment = "Left"; Instance.new("UICorner", TabBtn)
        
        if iconID then
            local Icon = Instance.new("ImageLabel", TabBtn)
            Icon.Size = UDim2.new(0, 16, 0, 16); Icon.Position = UDim2.new(0, 8, 0.5, -8); Icon.BackgroundTransparency = 1; Icon.Image = "rbxassetid://" .. iconID; Icon.ImageColor3 = Color3.fromRGB(150, 150, 150)
        end

        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.Visible = false; Page.ScrollBarThickness = 1; Page.AutomaticCanvasSize = "Y"
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(TabScroll:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Color3.fromRGB(150, 150, 150) end end
            Page.Visible = true; TabBtn.TextColor3 = ACCENT
        end)
        if #TabScroll:GetChildren() == 2 then Page.Visible = true; TabBtn.TextColor3 = ACCENT end

        local Tab = {}
        function Tab:CreateButton(opt)
            local b = Instance.new("TextButton", Page); b.Size = UDim2.new(0.95, 0, 0, 35); b.BackgroundColor3 = Color3.fromRGB(25, 25, 25); b.Text = opt.Name; b.TextColor3 = Color3.new(1,1,1); b.Font = "GothamMedium"; b.TextSize = 12; Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(opt.Callback)
        end
        return Tab
    end

    function NoirUI:Notify(title, msg)
        local n = Instance.new("Frame", ScreenGui); n.Size = UDim2.new(0, 220, 0, 65); n.Position = UDim2.new(1, 20, 0.8, 0); n.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", n); Instance.new("UIStroke", n).Color = ACCENT
        local t = Instance.new("TextLabel", n); t.Size = UDim2.new(1, -10, 0, 20); t.Position = UDim2.new(0, 10, 0, 5); t.Text = title; t.TextColor3 = ACCENT; t.BackgroundTransparency = 1; t.Font = "GothamBold"
        local m = Instance.new("TextLabel", n); m.Size = UDim2.new(1, -15, 0, 40); m.Position = UDim2.new(0, 10, 0, 22); m.Text = msg; m.TextColor3 = Color3.new(1,1,1); m.BackgroundTransparency = 1; m.TextWrapped = true; m.TextXAlignment = "Left"; m.TextYAlignment = "Top"
        TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -240, 0.8, 0)}):Play()
        task.delay(3, function() TweenService:Create(n, TweenInfo.new(0.5), {Position = UDim2.new(1, 20, 0.8, 0)}):Play(); task.wait(0.5); n:Destroy() end)
    end

    return Window
end

return NoirUI
