        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
        b.Text = options.Name .. ": OFF"
        
        b.MouseButton1Click:Connect(function()
            state = not state
            b.Text = options.Name .. ": " .. (state and "ON" or "OFF")
            TweenService:Create(b, TweenInfo.new(0.2), {
                BackgroundColor3 = state and ACCENT or Color3.fromRGB(30,30,30)
            }):Play()
            if options.Callback then options.Callback(state) end
        end)
        
        if options.Default then
            task.wait()
            b.MouseButton1Click:Fire()
        end
        
        return {SetValue = function(s) if s ~= state then b.MouseButton1Click:Fire() end end}
    end
    
    function NoirUI:CreateSlider(options)
        elementCount = elementCount + 1
        local min = options.Min or 0
        local max = options.Max or 100
        local value = options.Default or min
        
        local sFrame = Instance.new("Frame", Container)
        sFrame.Size = UDim2.new(1,0,0,65)
        sFrame.BackgroundColor3 = Color3.fromRGB(25,25,25)
        sFrame.LayoutOrder = elementCount
        Instance.new("UICorner", sFrame).CornerRadius = UDim.new(0,6)
        
        local sTitle = Instance.new("TextLabel", sFrame)
        sTitle.Size = UDim2.new(1,-12,0,25)
        sTitle.Position = UDim2.new(0,12,0,5)
        sTitle.Text = options.Name .. ": " .. value
        sTitle.TextColor3 = Color3.new(1,1,1)
        sTitle.Font = Enum.Font.GothamBold
        sTitle.TextSize = 13
        sTitle.BackgroundTransparency = 1
        sTitle.TextXAlignment = Enum.TextXAlignment.Left
        
        local valueLabel = Instance.new("TextLabel", sFrame)
        valueLabel.Size = UDim2.new(0,40,0,25)
        valueLabel.Position = UDim2.new(1,-52,0,5)
        valueLabel.Text = tostring(value)
        valueLabel.TextColor3 = ACCENT
        valueLabel.Font = Enum.Font.GothamBold
        valueLabel.TextSize = 13
        valueLabel.BackgroundTransparency = 1
        valueLabel.TextXAlignment = Enum.TextXAlignment.Right
        
        local sBack = Instance.new("Frame", sFrame)
        sBack.Size = UDim2.new(1,-24,0,6)
        sBack.Position = UDim2.new(0,12,0,45)
        sBack.BackgroundColor3 = Color3.fromRGB(50,50,50)
        Instance.new("UICorner", sBack).CornerRadius = UDim.new(1,0)
        
        local sFill = Instance.new("Frame", sBack)
        sFill.Size = UDim2.new((value - min)/(max - min),0,1,0)
        sFill.BackgroundColor3 = ACCENT
        Instance.new("UICorner", sFill).CornerRadius = UDim.new(1,0)
        
        local dragging = false
        
        local function updateValue(input)
            local relativePos = math.clamp((input.Position.X - sBack.AbsolutePosition.X) / sBack.AbsoluteSize.X, 0, 1)
            local newValue = math.floor(min + (max - min) * relativePos)
            value = newValue
            sFill.Size = UDim2.new(relativePos,0,1,0)
            sTitle.Text = options.Name .. ": " .. value
            valueLabel.Text = tostring(value)
            if options.Callback then options.Callback(value) end
        end
        
        sFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                updateValue(input)
            end
        end)
        
        UIS.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateValue(input)
            end
        end)
        
        UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        return {SetValue = function(v) 
            v = math.clamp(v, min, max)
            local percent = (v - min)/(max - min)
            sFill.Size = UDim2.new(percent,0,1,0)
            value = v
            sTitle.Text = options.Name .. ": " .. v
            valueLabel.Text = tostring(v)
            if options.Callback then options.Callback(v) end
        end}
    end
    
