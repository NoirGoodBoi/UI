    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.ScrollBarThickness = 2
    Container.BorderSizePixel = 0
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0,8)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder

    -- Notify System
    local NotifyHolder = ScreenGui:FindFirstChild("NotifyHolder") or Instance.new("Frame", ScreenGui)
    NotifyHolder.Name = "NotifyHolder"
    NotifyHolder.Size = UDim2.new(0,300,1,-20)
    NotifyHolder.Position = UDim2.new(1,-310,0,10)
    NotifyHolder.BackgroundTransparency = 1
    NotifyHolder.ClipsDescendants = false
    
    local NList = NotifyHolder:FindFirstChild("UIListLayout") or Instance.new("UIListLayout", NotifyHolder)
    NList.VerticalAlignment = Enum.VerticalAlignment.Bottom
    NList.Padding = UDim.new(0,10)
    NList.SortOrder = Enum.SortOrder.LayoutOrder

    local activeNotifies = {}
    
    function NoirUI:Notify(title, text, duration)
        duration = duration or 4
        
        -- Create notify frame
        local n = Instance.new("Frame", NotifyHolder)
        n.Size = UDim2.new(1,0,0,70)
        n.BackgroundColor3 = Color3.fromRGB(20,20,20)
        n.BackgroundTransparency = 0.3
        n.ClipsDescendants = true
        Instance.new("UICorner", n).CornerRadius = UDim.new(0,8)
        
        -- Stroke
        local ns = Instance.new("UIStroke", n)
        ns.Color = ACCENT
        ns.Thickness = 1.5
        ns.Transparency = 1
        
        -- Title
        local nt = Instance.new("TextLabel", n)
        nt.Size = UDim2.new(1,-15,0,25)
        nt.Position = UDim2.new(0,15,0,5)
        nt.Text = title
        nt.TextColor3 = Color3.new(1,1,1)
        nt.Font = Enum.Font.GothamBold
        nt.TextSize = 14
        nt.BackgroundTransparency = 1
        nt.TextXAlignment = Enum.TextXAlignment.Left
        
        -- Content
        local nc = Instance.new("TextLabel", n)
        nc.Size = UDim2.new(1,-15,0,30)
        nc.Position = UDim2.new(0,15,0,32)
        nc.Text = text
        nc.TextColor3 = Color3.fromRGB(200,200,200)
        nc.Font = Enum.Font.Gotham
        nc.TextSize = 12
        nc.BackgroundTransparency = 1
        nc.TextXAlignment = Enum.TextXAlignment.Left
        nc.TextWrapped = true
        nc.TextYAlignment = Enum.TextYAlignment.Top
        
        -- Progress bar
        local progress = Instance.new("Frame", n)
        progress.Size = UDim2.new(1,0,0,2)
        progress.Position = UDim2.new(0,0,1,-2)
        progress.BackgroundColor3 = ACCENT
        progress.BackgroundTransparency = 0.3
        
        -- Add to list
        table.insert(activeNotifies, n)
        
        -- Update positions (push up effect)
        local function updatePositions()
            for i, notify in ipairs(activeNotifies) do
                local targetPos = UDim2.new(0,0,0,(i-1) * 80)
                TweenService:Create(notify, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = targetPos}):Play()
            end
        end
        
        -- Animate in
        n.Position = UDim2.new(0,100,0,0)
        n.BackgroundTransparency = 1
        TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = UDim2.new(0,0,0,(#activeNotifies-1) * 80),
            BackgroundTransparency = 0.3
        }):Play()
        TweenService:Create(ns, TweenInfo.new(0.3), {Transparency = 0}):Play()
        
        -- Progress bar animation
        local progressTween = TweenService:Create(progress, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0,0,0,2)
        })
        progressTween:Play()
        
        -- Auto remove
        task.delay(duration, function()
            if n and n.Parent then
                -- Remove from list
                for i, v in ipairs(activeNotifies) do
                    if v == n then
                        table.remove(activeNotifies, i)
                        break
                    end
                end
                
                -- Animate out
                TweenService:Create(n, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
                    Position = UDim2.new(0,-100,0,0),
                    BackgroundTransparency = 1
                }):Play()
                TweenService:Create(ns, TweenInfo.new(0.15), {Transparency = 1}):Play()
                
                task.wait(0.25)
                if n and n.Parent then n:Destroy() end
                
                -- Update remaining positions
                updatePositions()
            end
        end)
        
        return n
    end

    -- Float Button
    local floatBtn = Instance.new("TextButton", ScreenGui)
    floatBtn.Size = UDim2.new(0,50,0,50)
    floatBtn.Position = UDim2.new(0,20,0.5,-25)
    floatBtn.BackgroundColor3 = Color3.fromRGB(20,20,20)
    floatBtn.Text = settings.FloatText or "●"
    floatBtn.TextColor3 = Color3.new(1,1,1)
    floatBtn.TextSize = 24
    floatBtn.TextScaled = true
    Instance.new("UICorner", floatBtn).CornerRadius = UDim.new(1,0)
    
    local floatStroke = Instance.new("UIStroke", floatBtn)
    floatStroke.Color = ACCENT
    floatStroke.Thickness = 2
    
    if settings.FloatIcon then
        floatBtn.Text = ""
        local fimg = Instance.new("ImageLabel", floatBtn)
        fimg.Size = UDim2.new(0.7,0,0.7,0)
        fimg.Position = UDim2.new(0.15,0,0.15,0)
        fimg.BackgroundTransparency = 1
        fimg.Image = "rbxassetid://" .. tostring(settings.FloatIcon):gsub("%D", "")
    end
    
    -- Float Button Drag System (FIXED)
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil
    
    floatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = floatBtn.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    floatBtn.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            floatBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    local mainVisible = true
    floatBtn.MouseButton1Click:Connect(function()
        if not dragging then
            mainVisible = not mainVisible
            Main.Visible = mainVisible
            TweenService:Create(Blur, TweenInfo.new(0.2), {Size = mainVisible and 12 or 0}):Play()
        end
    end)

    -- Helper functions for UI elements
    local windowElements = {}
    local elementCount = 0
    
    -- Dropdown class
    local Dropdown = {}
    Dropdown.__index = Dropdown
    
    function Dropdown:SetValue(value)
        self.selected = value
        self.button.Text = self.options[value] or value
        if self.callback then self.callback(value) end
        self:Close()
    end
    
    function Dropdown:Toggle()
        if self.open then
            self:Close()
        else
            self:Open()
        end
    end
    
    function Dropdown:Open()
        if self.open then return end
        self.open = true
        self.dropdown.Visible = true
        self.dropdown.Size = UDim2.new(1,0,0,0)
        TweenService:Create(self.dropdown, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = UDim2.new(1,0,0,math.min(#self.optionList * 30, 150))
        }):Play()
    end
    
    function Dropdown:Close()
        if not self.open then return end
        self.open = false
        TweenService:Create(self.dropdown, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
            Size = UDim2.new(1,0,0,0)
        }):Play()
        task.wait(0.15)
        self.dropdown.Visible = false
    end
    
