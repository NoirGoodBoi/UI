local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

local NoirUI = {}

function NoirUI:CreateWindow(settings)
    -- Xóa instance cũ nếu tồn tại
    local old = game.CoreGui:FindFirstChild("NoirUI")
    if old then old:Destroy() end
    
    -- Tạo ScreenGui
    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "NoirUI"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    -- Cài đặt màu sắc
    local ACCENT = settings.Accent or Color3.fromRGB(170, 85, 255)
    local BACKGROUND_IMAGE = settings.BackgroundImage or nil
    
    -- Hiệu ứng Blur
    local Blur = Instance.new("BlurEffect", game.Lighting)
    Blur.Size = 0
    TweenService:Create(Blur, TweenInfo.new(0.3), {Size = 12}):Play()
    
    -- Tạo cửa sổ chính
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 380, 0, 450)
    Main.Position = UDim2.new(0.5, -190, 0.5, -225)
    Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    Main.ClipsDescendants = true
    Instance.new("UICorner", Main)
    
    -- Xử lý Background (màu hoặc ảnh)
    if BACKGROUND_IMAGE then
        local bgImage = Instance.new("ImageLabel", Main)
        bgImage.Size = UDim2.new(1, 0, 1, 0)
        bgImage.BackgroundTransparency = 1
        bgImage.Image = "rbxassetid://" .. tostring(BACKGROUND_IMAGE):gsub("%D", "")
        bgImage.ScaleType = Enum.ScaleType.Crop
    end
    
    -- Viền đổi màu
    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Thickness = 2
    
    local Glow = Instance.new("UIStroke", Main)
    Glow.Thickness = 6
    Glow.Transparency = 0.7
    
    -- Vòng lặp đổi màu viền
    local colorLoopActive = true
    task.spawn(function()
        local hue = 0
        while colorLoopActive and Main and Main.Parent do
            hue = (hue + 0.005) % 1
            local c = Color3.fromHSV(hue, 1, 1)
            Stroke.Color = c
            Glow.Color = c
            task.wait(0.02)
        end
    end)
    
    -- Header
    local Header = Instance.new("Frame", Main)
    Header.Size = UDim2.new(1, 0, 0, 45)
    Header.BackgroundTransparency = 1
    
    local Title = Instance.new("TextLabel", Header)
    Title.Size = UDim2.new(1, -10, 1, 0)
    Title.Position = UDim2.new(0, 5, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = settings.Name or "Noir UI"
    Title.TextColor3 = Color3.new(1, 1, 1)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 18
    Title.TextXAlignment = Enum.TextXAlignment.Center
    
    if settings.HeaderIcon then
        local HIcon = Instance.new("ImageLabel", Header)
        HIcon.Size = UDim2.new(0, 28, 0, 28)
        HIcon.Position = UDim2.new(0, 12, 0.5, -14)
        HIcon.BackgroundTransparency = 1
        HIcon.Image = "rbxassetid://" .. tostring(settings.HeaderIcon):gsub("%D", "")
        Title.TextXAlignment = Enum.TextXAlignment.Left
        local padding = Instance.new("UIPadding", Title)
        padding.PaddingLeft = UDim.new(0, 50)
    end
    
    -- Container chính (ScrollingFrame)
    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1, -16, 1, -65)
    Container.Position = UDim2.new(0, 8, 0, 50)
    Container.BackgroundTransparency = 1
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.ScrollBarThickness = 4
    Container.ScrollBarImageColor3 = ACCENT
    Container.BorderSizePixel = 0
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 8)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- Hệ thống Notify cải tiến
    local NotifyHolder = Instance.new("Frame", ScreenGui)
    NotifyHolder.Name = "NotifyHolder"
    NotifyHolder.Size = UDim2.new(0, 300, 1, -20)
    NotifyHolder.Position = UDim2.new(1, -310, 0, 10)
    NotifyHolder.BackgroundTransparency = 1
    
    local NList = Instance.new("UIListLayout", NotifyHolder)
    NList.VerticalAlignment = Enum.VerticalAlignment.Bottom
    NList.Padding = UDim.new(0, 8)
    
    -- Hàm Notify mới với hiệu ứng
    function NoirUI:Notify(title, text, duration)
        duration = duration or 4
        
        local notify = Instance.new("Frame", NotifyHolder)
        notify.Size = UDim2.new(1, 0, 0, 70)
        notify.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        notify.BackgroundTransparency = 1
        notify.ClipsDescendants = true
        
        local corner = Instance.new("UICorner", notify)
        corner.CornerRadius = UDim.new(0, 8)
        
        local stroke = Instance.new("UIStroke", notify)
        stroke.Color = ACCENT
        stroke.Thickness = 1.5
        stroke.Transparency = 1
        
        -- Title text
        local titleLabel = Instance.new("TextLabel", notify)
        titleLabel.Size = UDim2.new(1, -16, 0, 28)
        titleLabel.Position = UDim2.new(0, 8, 0, 6)
        titleLabel.Text = title
        titleLabel.TextColor3 = Color3.new(1, 1, 1)
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.TextSize = 14
        titleLabel.BackgroundTransparency = 1
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        -- Content text
        local contentLabel = Instance.new("TextLabel", notify)
        contentLabel.Size = UDim2.new(1, -16, 0, 32)
        contentLabel.Position = UDim2.new(0, 8, 0, 34)
        contentLabel.Text = text
        contentLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        contentLabel.Font = Enum.Font.Gotham
        contentLabel.TextSize = 12
        contentLabel.BackgroundTransparency = 1
        contentLabel.TextXAlignment = Enum.TextXAlignment.Left
        contentLabel.TextWrapped = true
        contentLabel.TextYAlignment = Enum.TextYAlignment.Top
        
        -- Thanh tiến trình
        local progressBar = Instance.new("Frame", notify)
        progressBar.Size = UDim2.new(1, 0, 0, 3)
        progressBar.Position = UDim2.new(0, 0, 1, -3)
        progressBar.BackgroundColor3 = ACCENT
        progressBar.BorderSizePixel = 0
        
        -- Hiệu ứng fade in (trượt xuất hiện)
        notify.Position = UDim2.new(1, 50, 0, 0)
        notify.BackgroundTransparency = 1
        
        local tweenIn = TweenService:Create(notify, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 0
        })
        tweenIn:Play()
        
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0}):Play()
        
        -- Thanh tiến trình chạy
        local progressTween = TweenService:Create(progressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 0, 3)
        })
        progressTween:Play()
        
        -- Tự động xóa sau thời gian
        task.delay(duration, function()
            if not notify.Parent then return end
            
            -- Hiệu ứng fade out
            local tweenOut = TweenService:Create(notify, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 50, 0, 0),
                BackgroundTransparency = 1
            })
            tweenOut:Play()
            
            TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
            
            task.wait(0.4)
            if notify and notify.Parent then
                notify:Destroy()
            end
        end)
    end
    
    -- Biến cho Drag nút nổi
    local floatDragActive = false
    local floatDragStart = nil
    local floatStartPos = nil
    
    -- Tạo nút nổi
    local Float = Instance.new("TextButton", ScreenGui)
    Float.Size = UDim2.new(0, 50, 0, 50)
    Float.Position = UDim2.new(0, 20, 0.5, -25)
    Float.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Float.Text = settings.FloatIcon and "" or "⚙"
    Float.TextColor3 = Color3.new(1, 1, 1)
    Float.TextSize = 24
    Float.AutoButtonColor = false
    Instance.new("UICorner", Float).CornerRadius = UDim.new(1, 0)
    
    local floatStroke = Instance.new("UIStroke", Float)
    floatStroke.Color = ACCENT
    floatStroke.Thickness = 2
    
    if settings.FloatIcon then
        local fimg = Instance.new("ImageLabel", Float)
        fimg.Size = UDim2.new(0.6, 0, 0.6, 0)
        fimg.Position = UDim2.new(0.2, 0, 0.2, 0)
        fimg.BackgroundTransparency = 1
        fimg.Image = "rbxassetid://" .. tostring(settings.FloatIcon):gsub("%D", "")
    end
    
    -- Xử lý kéo nút nổi (FIXED)
    Float.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            floatDragActive = true
            floatDragStart = input.Position
            floatStartPos = Float.Position
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if floatDragActive and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - floatDragStart
            Float.Position = UDim2.new(
                floatStartPos.X.Scale,
                floatStartPos.X.Offset + delta.X,
                floatStartPos.Y.Scale,
                floatStartPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            floatDragActive = false
        end
    end)
    
    local isVisible = true
    Float.MouseButton1Click:Connect(function()
        if floatDragActive then return end
        isVisible = not isVisible
        Main.Visible = isVisible
        TweenService:Create(Blur, TweenInfo.new(0.2), {Size = isVisible and 12 or 0}):Play()
    end)
    
    -- Các hàm tạo thành phần UI
    local Window = {}
    local itemCount = 0
    
    -- Helper function cho Image có thể null
    local function addImageIfExists(parent, imageId, size, position)
        if imageId then
            local img = Instance.new("ImageLabel", parent)
            img.Size = size
            img.Position = position or UDim2.new(0, 0, 0, 0)
            img.BackgroundTransparency = 1
            img.Image = "rbxassetid://" .. tostring(imageId):gsub("%D", "")
            return img
        end
        return nil
    end
    
