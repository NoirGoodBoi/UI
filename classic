        colorGradient.BackgroundTransparency = 1
        colorGradient.ScaleType = Enum.ScaleType.Crop
        
        local gradientCorner = Instance.new("UICorner", colorGradient)
        gradientCorner.CornerRadius = UDim.new(0, 4)
        
        -- Hue slider
        local hueSlider = Instance.new("Frame", pickerPanel)
        hueSlider.Size = UDim2.new(0, 20, 1, 0)
        hueSlider.Position = UDim2.new(1, -24, 0, 0)
        hueSlider.BackgroundColor3 = Color3.new(1, 1, 1)
        hueSlider.BorderSizePixel = 0
        
        local hueCorner = Instance.new("UICorner", hueSlider)
        hueCorner.CornerRadius = UDim.new(0, 4)
        
        -- Hue gradient (FIXED - có màu)
        local hueGradient = Instance.new("UIGradient", hueSlider)
        hueGradient.Rotation = 90
        hueGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
        })
        
        -- Hue dot
        local hueDot = Instance.new("Frame", hueSlider)
        hueDot.Size = UDim2.new(1, 0, 0, 4)
        hueDot.Position = UDim2.new(0, 0, 0, 0)
        hueDot.BackgroundColor3 = Color3.new(1, 1, 1)
        hueDot.BorderSizePixel = 0
        
        local hueDotCorner = Instance.new("UICorner", hueDot)
        hueDotCorner.CornerRadius = UDim.new(1, 0)
        
        -- Color picker dot
        local pickerDot = Instance.new("Frame", colorGradient)
        pickerDot.Size = UDim2.new(0, 10, 0, 10)
        pickerDot.Position = UDim2.new(0, -5, 0, -5)
        pickerDot.BackgroundColor3 = Color3.new(1, 1, 1)
        pickerDot.BorderSizePixel = 1
        pickerDot.BorderColor3 = Color3.new(0, 0, 0)
        
        local dotCorner2 = Instance.new("UICorner", pickerDot)
        dotCorner2.CornerRadius = UDim.new(1, 0)
        
        local currentHue = 0
        local currentSat = 1
        local currentVal = 1
        
        local function updateColor()
            local finalColor = Color3.fromHSV(currentHue, currentSat, currentVal)
            colorDisplay.BackgroundColor3 = finalColor
            colorGradient.BackgroundColor3 = Color3.fromHSV(currentHue, 1, 1)
            
            if config.Callback then
                config.Callback(finalColor)
            end
        end
        
        local function updateHue(yPos)
            local huePercent = math.clamp(yPos / hueSlider.AbsoluteSize.Y, 0, 1)
            currentHue = 1 - huePercent
            hueDot.Position = UDim2.new(0, 0, huePercent, -2)
            updateColor()
        end
        
        local function updateColorPicker(xPos, yPos)
            local satPercent = math.clamp(xPos / colorGradient.AbsoluteSize.X, 0, 1)
            local valPercent = 1 - math.clamp(yPos / colorGradient.AbsoluteSize.Y, 0, 1)
            currentSat = satPercent
            currentVal = valPercent
            pickerDot.Position = UDim2.new(satPercent, -5, 1 - valPercent, -5)
            updateColor()
        end
        
        -- Set default color
        if config.Default then
            local h, s, v = config.Default:ToHSV()
            currentHue = h
            currentSat = s
            currentVal = v
            updateColor()
            
            task.wait(0.1)
            if colorGradient.AbsoluteSize.X > 0 then
                updateColorPicker(s * colorGradient.AbsoluteSize.X, (1 - v) * colorGradient.AbsoluteSize.Y)
                updateHue((1 - h) * hueSlider.AbsoluteSize.Y)
            end
        end
        
        -- Hue slider dragging
        local hueDragging = false
        colorGradient.BackgroundColor3 = Color3.fromHSV(currentHue, 1, 1)
        
        hueSlider.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                hueDragging = true
                local yPos = input.Position.Y - hueSlider.AbsolutePosition.Y
                updateHue(yPos)
                
                local conn
                conn = UIS.InputChanged:Connect(function(input2)
                    if hueDragging and input2.UserInputType == Enum.UserInputType.MouseMovement then
                        local newY = math.clamp(input2.Position.Y - hueSlider.AbsolutePosition.Y, 0, hueSlider.AbsoluteSize.Y)
                        updateHue(newY)
                    end
                end)
                
                UIS.InputEnded:Connect(function(input2)
                    if input2.UserInputType == Enum.UserInputType.MouseButton1 then
                        hueDragging = false
                        conn:Disconnect()
                    end
                end)
            end
        end)
        
        -- Color picker dragging
        local pickerDragging = false
        
        colorGradient.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                pickerDragging = true
                local xPos = input.Position.X - colorGradient.AbsolutePosition.X
                local yPos = input.Position.Y - colorGradient.AbsolutePosition.Y
                updateColorPicker(xPos, yPos)
                
                local conn
                conn = UIS.InputChanged:Connect(function(input2)
                    if pickerDragging and input2.UserInputType == Enum.UserInputType.MouseMovement then
                        local newX = math.clamp(input2.Position.X - colorGradient.AbsolutePosition.X, 0, colorGradient.AbsoluteSize.X)
                        local newY = math.clamp(input2.Position.Y - colorGradient.AbsolutePosition.Y, 0, colorGradient.AbsoluteSize.Y)
                        updateColorPicker(newX, newY)
                    end
                end)
                
                UIS.InputEnded:Connect(function(input2)
                    if input2.UserInputType == Enum.UserInputType.MouseButton1 then
                        pickerDragging = false
                        conn:Disconnect()
                    end
                end)
            end
        end)
        
        -- Toggle picker
        local panelOpen = false
        colorDisplay.MouseButton1Click:Connect(function()
            panelOpen = not panelOpen
            local targetSize = panelOpen and UDim2.new(1, 0, 0, 200) or UDim2.new(1, 0, 0, 45)
            TweenService:Create(pickerFrame, TweenInfo.new(0.3), {Size = targetSize}):Play()
            task.wait(0.15)
            pickerPanel.Visible = panelOpen
        end)
    end
    
    -- CreateDropdown (THÊM MỚI)
    function Window:CreateDropdown(config)
        itemCount = itemCount + 1
        
        local dropdownFrame = Instance.new("Frame", Container)
        dropdownFrame.Size = UDim2.new(1, 0, 0, 45)
        dropdownFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        dropdownFrame.LayoutOrder = itemCount
        dropdownFrame.ClipsDescendants = true
        
        local corner = Instance.new("UICorner", dropdownFrame)
        corner.CornerRadius = UDim.new(0, 6)
        
        local title = Instance.new("TextLabel", dropdownFrame)
        title.Size = UDim2.new(1, -16, 0, 24)
        title.Position = UDim2.new(0, 8, 0, 4)
        title.Text = config.Name or "Dropdown"
        title.TextColor3 = Color3.new(1, 1, 1)
        title.Font = Enum.Font.Gotham
        title.TextSize = 12
        title.BackgroundTransparency = 1
        title.TextXAlignment = Enum.TextXAlignment.Left
        
        local dropdownButton = Instance.new("TextButton", dropdownFrame)
        dropdownButton.Size = UDim2.new(1, -16, 0, 28)
        dropdownButton.Position = UDim2.new(0, 8, 0, 30)
        dropdownButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        dropdownButton.Text = config.Default or "Select option"
        dropdownButton.TextColor3 = Color3.new(1, 1, 1)
        dropdownButton.Font = Enum.Font.Gotham
        dropdownButton.TextSize = 13
        dropdownButton.AutoButtonColor = false
        
        local buttonCorner = Instance.new("UICorner", dropdownButton)
        buttonCorner.CornerRadius = UDim.new(0, 4)
        
        local arrow = Instance.new("TextLabel", dropdownButton)
        arrow.Size = UDim2.new(0, 20, 1, 0)
        arrow.Position = UDim2.new(1, -24, 0, 0)
        arrow.Text = "▼"
        arrow.TextColor3 = ACCENT
        arrow.Font = Enum.Font.GothamBold
        arrow.TextSize = 12
        arrow.BackgroundTransparency = 1
        
        local optionsPanel = Instance.new("ScrollingFrame", dropdownFrame)
        optionsPanel.Size = UDim2.new(1, -16, 0, 0)
        optionsPanel.Position = UDim2.new(0, 8, 0, 62)
        optionsPanel.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        optionsPanel.BorderSizePixel = 0
        optionsPanel.Visible = false
        optionsPanel.ScrollBarThickness = 3
        
        local panelCorner2 = Instance.new("UICorner", optionsPanel)
        panelCorner2.CornerRadius = UDim.new(0, 4)
        
        local optionsLayout = Instance.new("UIListLayout", optionsPanel)
        optionsLayout.Padding = UDim.new(0, 2)
        
        local isOpen = false
        local selectedValue = config.Default or config.Values[1]
        
        local function rebuildOptions()
            for _, child in ipairs(optionsPanel:GetChildren()) do
                if child:IsA("TextButton") then
                    child:Destroy()
                end
            end
            
            for _, value in ipairs(config.Values) do
                local optBtn = Instance.new("TextButton", optionsPanel)
                optBtn.Size = UDim2.new(1, 0, 0, 32)
                optBtn.Text = value
                optBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                optBtn.TextColor3 = Color3.new(1, 1, 1)
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextSize = 12
                optBtn.AutoButtonColor = false
                
                local optCorner = Instance.new("UICorner", optBtn)
                optCorner.CornerRadius = UDim.new(0, 3)
                
                optBtn.MouseButton1Click:Connect(function()
                    selectedValue = value
                    dropdownButton.Text = value
                    if config.Callback then config.Callback(value) end
                    
                    isOpen = false
                    TweenService:Create(optionsPanel, TweenInfo.new(0.2), {Size = UDim2.new(1, -16, 0, 0)}):Play()
                    task.wait(0.2)
                    optionsPanel.Visible = false
                    TweenService:Create(dropdownFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 45)}):Play()
                    arrow.Text = "▼"
                end)
                
                optBtn.MouseEnter:Connect(function()
                    TweenService:Create(optBtn, TweenInfo.new(0.1), {BackgroundColor3 = ACCENT}):Play()
                end)
                
                optBtn.MouseLeave:Connect(function()
                    TweenService:Create(optBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
                end)
            end
            
            optionsPanel.CanvasSize = UDim2.new(0, 0, 0, #config.Values * 34)
        end
        
        rebuildOptions()
        
        dropdownButton.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            
            if isOpen then
                optionsPanel.Visible = true
                arrow.Text = "▲"
                local targetHeight = math.min(#config.Values * 34 + 8, 150)
                TweenService:Create(optionsPanel, TweenInfo.new(0.2), {Size = UDim2.new(1, -16, 0, targetHeight)}):Play()
                TweenService:Create(dropdownFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 45 + targetHeight + 8)}):Play()
            else
                arrow.Text = "▼"
                TweenService:Create(optionsPanel, TweenInfo.new(0.2), {Size = UDim2.new(1, -16, 0, 0)}):Play()
                task.wait(0.2)
                optionsPanel.Visible = false
                TweenService:Create(dropdownFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 45)}):Play()
            end
        end)
        
        if config.Default then
            dropdownButton.Text = config.Default
            selectedValue = config.Default
        end
    end
    
    -- Khởi tạo thông báo
    NoirUI:Notify(settings.Name or "Noir UI", "Loaded Successfully!", 3)
    
    return Window
end

return NoirUI
