    function NoirUI:CreateColorPicker(options)
        elementCount = elementCount + 1
        local defaultColor = options.Default or Color3.new(1,1,1)
        
        local cpFrame = Instance.new("Frame", Container)
        cpFrame.Size = UDim2.new(1,0,0,45)
        cpFrame.BackgroundColor3 = Color3.fromRGB(25,25,25)
        cpFrame.LayoutOrder = elementCount
        cpFrame.ClipsDescendants = true
        Instance.new("UICorner", cpFrame).CornerRadius = UDim.new(0,6)
        
        local cpTitle = Instance.new("TextLabel", cpFrame)
        cpTitle.Size = UDim2.new(1,-60,0,45)
        cpTitle.Position = UDim2.new(0,12,0,0)
        cpTitle.Text = options.Name
        cpTitle.TextColor3 = Color3.new(1,1,1)
        cpTitle.Font = Enum.Font.GothamSemibold
        cpTitle.TextSize = 14
        cpTitle.BackgroundTransparency = 1
        cpTitle.TextXAlignment = Enum.TextXAlignment.Left
        
        local cpBox = Instance.new("TextButton", cpFrame)
        cpBox.Size = UDim2.new(0,40,0,25)
        cpBox.Position = UDim2.new(1,-52,0,10)
        cpBox.BackgroundColor3 = defaultColor
        cpBox.Text = ""
        Instance.new("UICorner", cpBox).CornerRadius = UDim.new(0,4)
        
        -- Color picker expanded panel
        local pickerPanel = Instance.new("Frame", cpFrame)
        pickerPanel.Size = UDim2.new(1,0,0,0)
        pickerPanel.Position = UDim2.new(0,0,0,45)
        pickerPanel.BackgroundColor3 = Color3.fromRGB(35,35,35)
        pickerPanel.Visible = false
        pickerPanel.ClipsDescendants = true
        Instance.new("UICorner", pickerPanel).CornerRadius = UDim.new(0,0,0,6)
        
        -- Color palette (gradient)
        local palette = Instance.new("ImageLabel", pickerPanel)
        palette.Size = UDim2.new(1,-20,0,120)
        palette.Position = UDim2.new(0,10,0,10)
        palette.BackgroundColor3 = Color3.new(1,1,1)
        palette.Image = "rbxassetid://4155801252"
        Instance.new("UICorner", palette).CornerRadius = UDim.new(0,4)
        
        -- Palette picker dot
        local paletteDot = Instance.new("Frame", palette)
        paletteDot.Size = UDim2.new(0,10,0,10)
        paletteDot.BackgroundColor3 = Color3.new(1,1,1)
        paletteDot.BorderSizePixel = 0
        Instance.new("UICorner", paletteDot).CornerRadius = UDim.new(1,0)
        paletteDot.ZIndex = 2
        
        -- Hue bar
        local hueBar = Instance.new("ImageLabel", pickerPanel)
        hueBar.Size = UDim2.new(1,-20,0,15)
        hueBar.Position = UDim2.new(0,10,0,140)
        hueBar.Image = "rbxassetid://3641079629"
        Instance.new("UICorner", hueBar).CornerRadius = UDim.new(1,0)
        
        -- Hue picker dot
        local hueDot = Instance.new("Frame", hueBar)
        hueDot.Size = UDim2.new(0,10,0,17)
        hueDot.Position = UDim2.new(0,-5,0,-1)
        hueDot.BackgroundColor3 = Color3.new(1,1,1)
        hueDot.BorderSizePixel = 0
        Instance.new("UICorner", hueDot).CornerRadius = UDim.new(1,0)
        
        local currentH, currentS, currentV = defaultColor:ToHSV()
        
        local function updatePickerDisplay()
            local finalColor = Color3.fromHSV(currentH, currentS, currentV)
            cpBox.BackgroundColor3 = finalColor
            palette.BackgroundColor3 = Color3.fromHSV(currentH, 1, 1)
            
            -- Update dot positions
            paletteDot.Position = UDim2.new(currentS, -5, 1 - currentV, -5)
            hueDot.Position = UDim2.new(1 - currentH, -5, 0, -1)
            
            if options.Callback then options.Callback(finalColor) end
        end
        
        -- Palette dragging
        local draggingPalette = false
        palette.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingPalette = true
                local function update()
                    local mousePos = UIS:GetMouseLocation()
                    local relativeX = math.clamp((mousePos.X - palette.AbsolutePosition.X) / palette.AbsoluteSize.X, 0, 1)
                    local relativeY = math.clamp((mousePos.Y - palette.AbsolutePosition.Y) / palette.AbsoluteSize.Y, 0, 1)
                    currentS = relativeX
                    currentV = 1 - relativeY
                    updatePickerDisplay()
                end
                
                local conn; conn = UIS.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement and draggingPalette then
                        update()
                    end
                end)
                
                UIS.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingPalette = false
                        conn:Disconnect()
                    end
                end)
                update()
            end
        end)
        
        -- Hue dragging
        local draggingHue = false
        hueBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingHue = true
                local function update()
                    local mousePos = UIS:GetMouseLocation()
                    local relativeX = math.clamp((mousePos.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                    currentH = 1 - relativeX
                    updatePickerDisplay()
                end
                
                local conn; conn = UIS.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement and draggingHue then
                        update()
                    end
                end)
                
                UIS.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingHue = false
                        conn:Disconnect()
                    end
                end)
                update()
            end
        end)
        
        local open = false
        cpBox.MouseButton1Click:Connect(function()
            open = not open
            pickerPanel.Visible = true
            TweenService:Create(cpFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
                Size = open and UDim2.new(1,0,0,200) or UDim2.new(1,0,0,45)
            }):Play()
            TweenService:Create(pickerPanel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                Size = open and UDim2.new(1,0,0,155) or UDim2.new(1,0,0,0)
            }):Play()
            if not open then
                task.wait(0.2)
                pickerPanel.Visible = false
            end
        end)
        
        updatePickerDisplay()
        
        return {SetColor = function(color) 
            currentH, currentS, currentV = color:ToHSV()
            updatePickerDisplay()
        end}
    end
    
    function NoirUI:CreateDropdown(options)
        elementCount = elementCount + 1
        local dropdownOptions = options.Options or {}
        local default = options.Default or dropdownOptions[1]
        
        local frame = Instance.new("Frame", Container)
        frame.Size = UDim2.new(1,0,0,45)
        frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
        frame.LayoutOrder = elementCount
        frame.ClipsDescendants = true
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)
        
        local title = Instance.new("TextLabel", frame)
        title.Size = UDim2.new(1,-12,0,25)
        title.Position = UDim2.new(0,12,0,5)
        title.Text = options.Name or "Dropdown"
        title.TextColor3 = Color3.new(1,1,1)
        title.Font = Enum.Font.GothamBold
        title.TextSize = 13
        title.BackgroundTransparency = 1
        title.TextXAlignment = Enum.TextXAlignment.Left
        
        local selectButton = Instance.new("TextButton", frame)
        selectButton.Size = UDim2.new(1,-24,0,30)
        selectButton.Position = UDim2.new(0,12,0,10)
        selectButton.Text = default
        selectButton.BackgroundColor3 = Color3.fromRGB(40,40,40)
        selectButton.TextColor3 = Color3.new(1,1,1)
        selectButton.Font = Enum.Font.Gotham
        selectButton.TextSize = 13
        Instance.new("UICorner", selectButton).CornerRadius = UDim.new(0,4)
        
        local dropdownFrame = Instance.new("ScrollingFrame", frame)
        dropdownFrame.Size = UDim2.new(1,-24,0,0)
        dropdownFrame.Position = UDim2.new(0,12,0,45)
        dropdownFrame.BackgroundColor3 = Color3.fromRGB(40,40,40)
        dropdownFrame.ScrollBarThickness = 4
        dropdownFrame.Visible = false
        dropdownFrame.CanvasSize = UDim2.new(0,0,0, #dropdownOptions * 30)
        Instance.new("UICorner", dropdownFrame).CornerRadius = UDim.new(0,4)
        
        local dropdownLayout = Instance.new("UIListLayout", dropdownFrame)
        dropdownLayout.Padding = UDim.new(0,2)
        
        local isOpen = false
        local optionButtons = {}
        
        for i, opt in ipairs(dropdownOptions) do
            local btn = Instance.new("TextButton", dropdownFrame)
            btn.Size = UDim2.new(1,0,0,30)
            btn.Text = opt
            btn.BackgroundColor3 = Color3.fromRGB(45,45,45)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 13
            btn.BackgroundTransparency = 0.3
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,4)
            
            btn.MouseButton1Click:Connect(function()
                selectButton.Text = opt
                if options.Callback then options.Callback(opt) end
                if isOpen then
                    isOpen = false
                    TweenService:Create(dropdownFrame, TweenInfo.new(0.15), {Size = UDim2.new(1,-24,0,0)}):Play()
                    task.wait(0.15)
                    dropdownFrame.Visible = false
                    TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(1,0,0,45)}):Play()
                end
            end)
            
            table.insert(optionButtons, btn)
        end
        
        selectButton.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            if isOpen then
                dropdownFrame.Visible = true
                local height = math.min(#dropdownOptions * 32, 150)
                TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(1,0,0,45 + height)}):Play()
                TweenService:Create(dropdownFrame, TweenInfo.new(0.15), {Size = UDim2.new(1,-24,0,height)}):Play()
            else
                TweenService:Create(dropdownFrame, TweenInfo.new(0.15), {Size = UDim2.new(1,-24,0,0)}):Play()
                TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(1,0,0,45)}):Play()
                task.wait(0.15)
                dropdownFrame.Visible = false
            end
        end)
        
        return {SetValue = function(val)
            for _, opt in ipairs(dropdownOptions) do
                if opt == val then
                    selectButton.Text = val
                    if options.Callback then options.Callback(val) end
                    break
                end
            end
        end}
    end
    
    -- Initial notify
    NoirUI:Notify(settings.Name or "Noir UI", "Loaded Successfully!", 3)
    
    return NoirUI
end

return NoirUI
