    -- CreateToggle
    function Window:CreateToggle(config)
        itemCount = itemCount + 1
        
        local toggle = Instance.new("TextButton", Container)
        toggle.Size = UDim2.new(1, 0, 0, 38)
        toggle.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        toggle.TextColor3 = Color3.new(1, 1, 1)
        toggle.Font = Enum.Font.Gotham
        toggle.TextSize = 14
        toggle.LayoutOrder = itemCount
        toggle.AutoButtonColor = false
        
        local corner = Instance.new("UICorner", toggle)
        corner.CornerRadius = UDim.new(0, 6)
        
        local state = false
        toggle.Text = config.Name .. ": OFF"
        
        toggle.MouseButton1Click:Connect(function()
            state = not state
            toggle.Text = config.Name .. ": " .. (state and "ON" or "OFF")
            
            local targetColor = state and ACCENT or Color3.fromRGB(30, 30, 30)
            TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
            
            if config.Callback then config.Callback(state) end
        end)
        
        toggle.MouseEnter:Connect(function()
            if not state then
                TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
            end
        end)
        
        toggle.MouseLeave:Connect(function()
            if not state then
                TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
            end
        end)
