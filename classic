local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

local NoirUI = {}

function NoirUI:CreateWindow(settings)
    local old = game.CoreGui:FindFirstChild("NoirUI")
    if old then old:Destroy() end

    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "NoirUI"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local ACCENT = settings.Accent or Color3.fromRGB(170,85,255)
    local BACKGROUND_SETTING = settings.Background or "color" -- "color" hoặc "image"
    local BACKGROUND_IMAGE = settings.BackgroundImage or ""
    
    -- Blur effect
    local Blur = Instance.new("BlurEffect", game.Lighting)
    Blur.Size = 0
    TweenService:Create(Blur, TweenInfo.new(0.3), {Size = 12}):Play()

    -- Main Window
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0,380,0,400)
    Main.Position = UDim2.new(0.5,-190,0.5,-200)
    Main.BackgroundColor3 = Color3.fromRGB(10,10,10)
    Main.BackgroundTransparency = 0
    Instance.new("UICorner", Main)
    
    -- Background image
    if BACKGROUND_SETTING == "image" and BACKGROUND_IMAGE ~= "" then
        local bgImage = Instance.new("ImageLabel", Main)
        bgImage.Size = UDim2.new(1,0,1,0)
        bgImage.BackgroundTransparency = 1
        bgImage.Image = "rbxassetid://" .. tostring(BACKGROUND_IMAGE):gsub("%D", "")
        bgImage.ImageTransparency = 0.85
        Instance.new("UICorner", bgImage).CornerRadius = UDim.new(0,8)
    end
    
    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Thickness = 2
    local Glow = Instance.new("UIStroke", Main)
    Glow.Thickness = 6
    Glow.Transparency = 0.7

    -- Rainbow border effect
    local rainbowActive = true
    task.spawn(function()
        while rainbowActive and Main and Main.Parent do
            for i = 0,1,0.02 do
                if not rainbowActive or not Main or not Main.Parent then break end
                local c = Color3.fromHSV(i,1,1)
                Stroke.Color = c
                Glow.Color = c
                task.wait(0.02)
            end
        end
    end)

    -- Header
    local Header = Instance.new("Frame", Main)
    Header.Size = UDim2.new(1,0,0,45)
    Header.BackgroundTransparency = 1
    
    local Title = Instance.new("TextLabel", Header)
    Title.Size = UDim2.new(1,-10,1,0)
    Title.Position = UDim2.new(0,5,0,0)
    Title.BackgroundTransparency = 1
    Title.Text = settings.Name or "Noir UI"
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 18

    if settings.HeaderIcon then
        local HIcon = Instance.new("ImageLabel", Header)
        HIcon.Size = UDim2.new(0,25,0,25)
        HIcon.Position = UDim2.new(0,10,0.5,-12.5)
        HIcon.BackgroundTransparency = 1
        HIcon.Image = "rbxassetid://" .. tostring(settings.HeaderIcon):gsub("%D", "")
