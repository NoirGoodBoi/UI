    -- CreateSlider (FIXED)
    function Window:CreateSlider(config)
        itemCount = itemCount + 1
        
        local sliderFrame = Instance.new("Frame", Container)
        sliderFrame.Size = UDim2.new(1, 0, 0, 58)
        sliderFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        sliderFrame.LayoutOrder = itemCount
        sliderFrame.ClipsDescendants = true
        
        local corner = Instance.new("UICorner", sliderFrame)
        corner.CornerRadius = UDim.new(0, 6)
        
        local title = Instance.new("TextLabel", sliderFrame)
        title.Size = UDim2.new(1, -16, 0, 24)
        title.Position = UDim2.new(0, 8, 0, 4)
        title.Text = config.Name .. ": " .. tostring(config.Default or config.Min)
        title.TextColor3 = Color3.new(1, 1, 1)
        title.Font = Enum.Font.Gotham
        title.TextSize = 12
        title.BackgroundTransparency = 1
        title.TextXAlignment = Enum.TextXAlignment.Left
        
        local valueDisplay = Instance.new("TextLabel", sliderFrame)
        valueDisplay.Size = UDim2.new(0, 45, 0, 24)
        valueDisplay.Position = UDim2.new(1, -53, 0, 4)
        valueDisplay.Text = tostring(config.Default or config.Min)
        valueDisplay.TextColor3 = ACCENT
        valueDisplay.Font = Enum.Font.GothamBold
        valueDisplay.TextSize = 12
        valueDisplay.BackgroundTransparency = 1
        valueDisplay.TextXAlignment = Enum.TextXAlignment.Right
        
        local sliderBack = Instance.new("Frame", sliderFrame)
        sliderBack.Size = UDim2.new(1, -16, 0, 6)
        sliderBack.Position = UDim2.new(0, 8, 0, 38)
        sliderBack.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        sliderBack.BorderSizePixel = 0
        
        local sliderCorner = Instance.new("UICorner", sliderBack)
        sliderCorner.CornerRadius = UDim.new(1, 0)
        
        local sliderFill = Instance.new("Frame", sliderBack)
        sliderFill.Size = UDim2.new(0, 0, 1, 0)
        sliderFill.BackgroundColor3 = ACCENT
        sliderFill.BorderSizePixel = 0
        
        local fillCorner = Instance.new("UICorner", sliderFill)
        fillCorner.CornerRadius = UDim.new(1, 0)
        
        local dot = Instance.new("Frame", sliderBack)
        dot.Size = UDim2.new(0, 12, 0, 12)
        dot.Position = UDim2.new(0, -6, 0.5, -6)
        dot.BackgroundColor3 = ACCENT
        dot.BorderSizePixel = 0
        
        local dotCorner = Instance.new("UICorner", dot)
        dotCorner.CornerRadius = UDim.new(1, 0)
        
        local currentValue = config.Default or config.Min
        local min = config.Min or 0
        local max = config.Max or 100
        
        local function updateValue(value)
            value = math.clamp(value, min, max)
            currentValue = value
            local percent = (value - min) / (max - min)
            sliderFill.Size = UDim2.new(percent, 0, 1, 0)
            dot.Position = UDim2.new(percent, -6, 0.5, -6)
            title.Text = config.Name .. ": " .. math.floor(value)
            valueDisplay.Text = math.floor(value)
            if config.Callback then config.Callback(math.floor(value)) end
        end
        
        if config.Default then
            updateValue(config.Default)
        end
        
        local dragging = false
        local dragConnection = nil
        local endConnection = nil
        
        local function startDrag()
            dragging = true
            
            if dragConnection then dragConnection:Disconnect() end
            if endConnection then endConnection:Disconnect() end
            
            dragConnection = UIS.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local mousePos = input.Position.X
                    local sliderPos = sliderBack.AbsolutePosition.X
                    local sliderWidth = sliderBack.AbsoluteSize.X
                    
                    local percent = math.clamp((mousePos - sliderPos) / sliderWidth, 0, 1)
                    local value = min + (max - min) * percent
                    updateValue(value)
                end
            end)
            
            endConnection = UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
                    dragging = false
                    if dragConnection then dragConnection:Disconnect() end
                    if endConnection then endConnection:Disconnect() end
                end
            end)
        end
        
        sliderBack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = input.Position.X
                local sliderPos = sliderBack.AbsolutePosition.X
                local sliderWidth = sliderBack.AbsoluteSize.X
                
                local percent = math.clamp((mousePos - sliderPos) / sliderWidth, 0, 1)
                local value = min + (max - min) * percent
                updateValue(value)
                startDrag()
            end
        end)
        
        dot.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                startDrag()
            end
        end)
    end
    
